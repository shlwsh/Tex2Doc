# Tex2Doc 浏览器扩展 - 环境变量模板
#
# 使用方法：
#   1. 复制本文件为 .env.local（已加入 .gitignore）
#        cp .env.example .env.local
#   2. 按需修改下方变量
#
# 注意：本文件会进入版本库，请勿填写任何密钥/令牌。

# === API 配置 =====================================================
# Vite 要求以 VITE_ 前缀才能通过 import.meta.env 访问
# 默认：本地 doc-server（端口 2624，与本机 API 服务一致）
VITE_API_BASE_URL=http://localhost:2624
# VITE_API_BASE_URL=https://api.tex2doc.cn     # 生产环境
VITE_API_VERSION=v1

# === 开发模式配置 =================================================
VITE_DEV_MODE=true
VITE_LOG_LEVEL=debug