{
  "name": "tex2doc-browser-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Tex2Doc Browser Extension - LaTeX to DOCX converter for Chrome, Edge, Firefox, and Safari",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:chrome": "wxt -b chrome",
    "dev:edge": "wxt -b chrome --mode edge",
    "dev:firefox": "wxt -b firefox",
    "dev:safari": "wxt -b safari",
    "build": "wxt build",
    "build:chrome": "wxt build -b chrome && node scripts/fix-chrome-manifest.mjs",
    "build:edge": "wxt build -b chrome --mode edge",
    "build:firefox": "wxt build -b firefox",
    "build:safari": "wxt build -b safari",
    "build:all": "npm run build:chrome && npm run build:edge && npm run build:safari",
    "zip": "wxt zip",
    "zip:chrome": "wxt zip -b chrome",
    "zip:edge": "wxt zip -b chrome --mode edge",
    "zip:firefox": "wxt zip -b firefox",
    "zip:safari": "wxt zip -b safari",
    "zip:all": "npm run zip:chrome && npm run zip:edge && npm run zip:safari",
    "preview": "wxt preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@wxt-dev/module-react": "^1.2.2",
    "fflate": "^0.8.2",
    "idb": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "webextension-polyfill": "^0.12.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.39",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite-plugin-pwa": "^0.20.1",
    "vitest": "^1.6.0",
    "wxt": "^0.20.27"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
