{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["src/shared/*"],
      "@api/*": ["src/api/*"],
      "@browser/*": ["src/browser/*"],
      "@state/*": ["src/state/*"],
      "@ui/*": ["src/ui/*"]
    },
    "types": ["vite/client", "wxt/browser", "webextension-polyfill"]
  },
  "include": ["src/**/*", "wxt.config.ts"],
  "exclude": ["node_modules", "dist"],
  "lib": ["ES2022"]
}
