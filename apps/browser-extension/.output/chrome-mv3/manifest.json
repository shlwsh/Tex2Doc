{
  "manifest_version": 3,
  "name": "Tex2Doc - LaTeX to Word",
  "description": "Convert LaTeX documents to Word (.docx) directly in your browser",
  "version": "0.1.0",
  "short_name": "Tex2Doc",
  "icons": {
    "16": "/icons/icon16.png",
    "32": "/icons/icon32.png",
    "48": "/icons/icon48.png",
    "128": "/icons/icon128.png"
  },
  "author": "Tex2Doc Project",
  "homepage_url": "https://tex2doc.cn",
  "support_url": "https://tex2doc.cn/support",
  "privacy_policy_url": "https://tex2doc.cn/privacy",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tex2Doc"
  },
  "permissions": [
    "storage",
    "downloads",
    "contextMenus",
    "notifications",
    "alarms",
    "sidePanel"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; worker-src 'self'; object-src 'self'"
  },
  "host_permissions": [
    "https://127.0.0.1:2624/*",
    "http://127.0.0.1:2624/*"
  ],
  "optional_host_permissions": [
    "https://www.overleaf.com/*",
    "https://*.overleaf.com/*",
    "https://arxiv.org/*",
    "https://*.arxiv.org/*"
  ],
  "background": {
    "type": "module",
    "service_worker": "background.js"
  },
  "options_ui": {
    "open_in_tab": false,
    "page": "options.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}