import {
    Button,
    VerticalBox,
    HorizontalBox,
    LineEdit,
    TextEdit,
    ComboBox,
    ProgressIndicator,
    ListView,
    Switch,
} from "std-widgets.slint";
import { PlanEntry, JobRow, RechargeRow, CloudConversionRow, ConversionMode, FeedbackThreadRow } from "types.slint";

component NavButton inherits Rectangle {
    in property <string> label;
    in property <string> detail;
    in property <bool> selected: false;
    in property <color> accent: #2563eb;
    in property <color> text-primary: #172033;
    in property <color> text-muted: #6b778c;
    callback clicked();

    height: 54px;
    border-radius: 8px;
    background: selected ? #eff6ff : #00000000;

    TouchArea { clicked => { root.clicked(); } }

    HorizontalBox {
        padding-left: 14px;
        padding-right: 12px;
        spacing: 10px;

        Rectangle {
            width: 4px;
            height: 28px;
            border-radius: 2px;
            background: root.selected ? root.accent : #00000000;
        }

        VerticalBox {
            vertical-stretch: 1;
            spacing: 2px;
            Text {
                text: root.label;
                font-size: 14px;
                font-weight: root.selected ? 700 : 500;
                color: root.selected ? root.accent : root.text-primary;
                vertical-alignment: bottom;
            }
            Text {
                text: root.detail;
                font-size: 11px;
                color: root.text-muted;
                overflow: elide;
                vertical-alignment: top;
            }
        }
    }
}

component MetricTile inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> note;
    in property <color> surface: #ffffff;
    in property <color> border: #d7dee8;
    in property <color> text-primary: #172033;
    in property <color> text-muted: #6b778c;
    in property <color> accent: #2563eb;

    min-height: 86px;
    border-radius: 8px;
    border-color: border;
    background: surface;

    VerticalBox {
        padding: 14px;
        spacing: 5px;
        Text { text: root.label; font-size: 11px; color: root.text-muted; }
        Text { text: root.value; font-size: 22px; font-weight: 700; color: root.text-primary; overflow: elide; }
        Text { text: root.note; font-size: 11px; color: root.accent; overflow: elide; }
    }
}

component StatusPill inherits Rectangle {
    in property <string> text;
    in property <color> bg: #eff6ff;
    in property <color> fg: #2563eb;

    height: 26px;
    min-width: 86px;
    border-radius: 999px;
    background: bg;

    Text {
        text: root.text;
        color: root.fg;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component ConversionRecordsTable inherits Rectangle {
    in property <[CloudConversionRow]> rows;
    in property <string> empty-text;
    in property <string> status-label;
    in property <string> main-label;
    in property <string> profile-label;
    in property <string> updated-label;
    in property <string> error-label;
    in property <color> surface: #ffffff;
    in property <color> surface-alt: #f1f5f9;
    in property <color> border: #d7dee8;
    in property <color> text-primary: #172033;
    in property <color> text-secondary: #42526b;
    in property <color> text-muted: #6b778c;
    in property <color> accent: #2563eb;
    in property <color> success: #0f8a5f;
    in property <color> danger: #c2413a;

    border-radius: 8px;
    border-color: border;
    background: surface;

    VerticalBox {
        Rectangle {
            height: 34px;
            background: root.surface-alt;
            HorizontalBox {
                padding: 8px;
                spacing: 10px;
                Text { text: root.status-label; width: 96px; font-size: 11px; font-weight: 700; color: root.text-primary; }
                Text { text: root.main-label; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: root.text-primary; }
                Text { text: root.profile-label; width: 110px; font-size: 11px; font-weight: 700; color: root.text-primary; }
                Text { text: root.updated-label; width: 138px; font-size: 11px; font-weight: 700; color: root.text-primary; }
                Text { text: root.error-label; width: 150px; font-size: 11px; font-weight: 700; color: root.text-primary; }
            }
        }
        if rows.length == 0: Text {
            text: root.empty-text;
            height: 96px;
            font-size: 13px;
            color: root.text-muted;
            horizontal-alignment: center;
            vertical-alignment: center;
            wrap: word-wrap;
        }
        ListView {
            visible: rows.length > 0;
            height: 390px;
            for row[idx] in rows: Rectangle {
                min-height: 42px;
                background: Math.mod(idx, 2) == 0 ? root.surface : root.surface-alt;
                HorizontalBox {
                    padding: 8px;
                    spacing: 10px;
                    Text { text: row.status; width: 96px; font-size: 11px; color: row.status == "Completed" ? root.success : (row.status == "Failed" ? root.danger : root.accent); overflow: elide; }
                    Text { text: row.main-tex; horizontal-stretch: 1; font-size: 11px; color: root.text-secondary; overflow: elide; }
                    Text { text: row.profile; width: 110px; font-size: 11px; color: root.text-muted; overflow: elide; }
                    Text { text: row.updated-at; width: 138px; font-size: 10px; color: root.text-muted; overflow: elide; }
                    Text { text: row.error; width: 150px; font-size: 10px; color: row.error == "-" ? root.text-muted : root.danger; overflow: elide; }
                }
            }
        }
    }
}

