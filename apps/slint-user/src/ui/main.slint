    in-out property <string> t-convert-detected: "detected";
    in-out property <string> t-convert-status: "Status";
    in-out property <string> t-convert-ready: "Ready. Enter a project path and click Convert.";
    in-out property <string> t-settings-service: "Service";
    in-out property <string> t-settings-api-base-url-placeholder: "API base URL";
    in-out property <string> t-settings-default-params: "Default Conversion Parameters";
    in-out property <string> t-settings-default-profile: "Default Profile";
    in-out property <string> t-settings-default-quality: "Default Quality";
    in-out property <string> t-settings-default-output-dir: "Default Output Directory";
    in-out property <string> t-settings-updates: "Updates";
    in-out property <string> t-settings-release-channel-placeholder: "Release channel";
    in-out property <string> t-settings-check-update: "Check Update";
    in-out property <string> t-settings-checking-update: "Checking for updates...";
    in-out property <string> t-settings-appearance: "Appearance";
    in-out property <string> t-settings-language: "Language";
    in-out property <string> t-settings-theme: "Theme";
    in-out property <string> t-settings-apply-appearance: "Apply Appearance";
    in-out property <string> t-theme-default: "Default";
    in-out property <string> t-theme-blue: "Blue";
    in-out property <string> t-theme-green: "Green";
    in-out property <string> t-theme-purple: "Purple";
    in-out property <string> t-theme-orange: "Orange";
    in-out property <string> t-theme-dark: "Dark";
    in-out property <string> t-settings-about: "About";
    in-out property <string> t-settings-product: "Product";
    in-out property <string> t-settings-version: "Version";
    in-out property <string> t-account-sign-in-register: "Sign In / Register";
    in-out property <string> t-account-email: "Email";
    in-out property <string> t-account-password: "Password";
    in-out property <string> t-account-login: "Login";
    in-out property <string> t-account-register: "Register";
    in-out property <string> t-account-refresh: "Refresh";
    in-out property <string> t-account-logout: "Logout";
    in-out property <string> t-account-account: "Account";
    in-out property <string> t-account-display-name: "Display Name";
    in-out property <string> t-account-plan: "Plan";
    in-out property <string> t-account-quota: "Quota";
    in-out property <string> t-account-refresh-usage: "Refresh Usage";
    in-out property <string> t-account-signing-in: "Signing in...";
    in-out property <string> t-account-registering: "Registering...";
    in-out property <string> t-account-refreshing: "Refreshing...";
    in-out property <string> t-account-refreshing-usage: "Refreshing usage...";
    in-out property <string> t-billing-subscribe-manage: "Subscribe / Manage";
    in-out property <string> t-billing-plan-id: "Plan ID";
    in-out property <string> t-billing-plans: "Plans";
    in-out property <string> t-billing-checkout: "Checkout";
    in-out property <string> t-billing-portal: "Billing Portal";
    in-out property <string> t-billing-loading-plans: "Loading plans...";
    in-out property <string> t-billing-creating-checkout: "Creating checkout session...";
    in-out property <string> t-billing-opening-portal: "Opening billing portal...";
    in-out property <string> t-history-recent-jobs: "Recent Jobs";
    in-out property <string> t-history-no-recent-jobs: "No recent jobs.";
    in-out property <string> t-history-open-output: "Open Output";
    in-out property <string> t-history-open-report: "Open Report";
    in-out property <string> t-history-export-diagnostics: "Export Diagnostics";
    in-out property <string> t-history-exporting-diagnostics: "Exporting diagnostics...";
    in-out property <string> t-nav-recharge: "Recharge";
    in-out property <string> t-nav-conversion-records: "Conversion Records";
    in-out property <string> t-nav-recharge-records: "Recharge Records";
    in-out property <string> t-nav-sign-in-first: "Sign in first";
    in-out property <string> t-nav-quota-billing: "Quota and billing";
    in-out property <string> t-nav-cloud-engine: "Cloud semantic engine";
    in-out property <string> t-nav-jobs-reports: "Jobs and reports";
    in-out property <string> t-nav-mock-payment-history: "Mock payment history";
    in-out property <string> t-auth-required-title: "Sign in to Tex2Doc";
    in-out property <string> t-auth-required-subtitle: "Login is required before using conversion, recharge, records, and account modules.";
    in-out property <string> t-auth-demo-hint: "Demo account: demo@example.com / secret";
    in-out property <string> t-auth-api-hint: "Start doc-server first, or change the API base URL below.";
    in-out property <string> t-account-overview-title: "Account Overview";
    in-out property <string> t-account-active-subscription: "Active subscription";
    in-out property <string> t-account-guest-mode: "Guest mode";
    in-out property <string> t-account-signed-in-short: "Signed in";
    in-out property <string> t-account-status: "Status";
    in-out property <string> t-recharge-title: "Recharge";
    in-out property <string> t-recharge-subtitle: "Enter a redeem code to add conversion credits immediately.";
    in-out property <string> t-recharge-by-count: "Redeem code";
    in-out property <string> t-recharge-by-date: "Redeemable packages";
    in-out property <string> t-recharge-mock-pay: "Redeem";
    in-out property <string> t-records-conversion-title: "Conversion Records";
    in-out property <string> t-records-conversion-subtitle: "Recent local and cloud conversion jobs.";
    in-out property <string> t-records-recharge-title: "Recharge Records";
    in-out property <string> t-records-recharge-subtitle: "Mock recharge events and billing status are shown here until the commercial API exposes a dedicated record endpoint.";
    in-out property <string> t-records-no-recharge: "No recharge record yet. Complete a mock payment from the Recharge page.";
    in-out property <string> t-dialog-view-profile: "View Profile";
    in-out property <string> t-dialog-change-password: "Change Password";
    in-out property <string> t-dialog-account-details: "Account Details";
    in-out property <string> t-dialog-close: "Close";
    in-out property <string> t-dialog-cancel: "Cancel";
    in-out property <string> t-dialog-confirm: "Confirm";

    callback convert-clicked(string, string, string, string);
    callback cloud-convert-clicked(string, string, string, string, string, string);
    callback detect-profile-clicked(string);
    callback login-clicked(string, string, string);
    callback register-clicked(string, string, string);
    callback refresh-login-clicked(string);
    callback logout-clicked();
    callback refresh-usage-clicked(string);
    callback show-plans-clicked(string);
    callback checkout-clicked(string, string);
    callback billing-portal-clicked(string);
    callback redeem-code-clicked(string, string);
    callback refresh-conversion-records-clicked(string);
    callback refresh-recharge-records-clicked(string);
    callback change-plan-clicked(string);
    callback check-update-clicked(string, string);
    callback apply-appearance-clicked(string, string);
    callback choose-project-folder-clicked(string, string);
    callback choose-project-zip-clicked(string, string);
    callback choose-output-clicked(string);
    callback save-settings-clicked();
    callback open-output-clicked(string);
    callback open-report-clicked(string);
    callback remove-job-clicked(string);
    callback clear-jobs-clicked();
    callback export-diagnostics-clicked(string, string, string, string, string, string, string, string);

    if !is-signed-in: Rectangle {
        background: color-window-bg;

        VerticalBox {
            padding: 34px;
            spacing: 18px;

            Rectangle { vertical-stretch: 1; }

            Rectangle {
                horizontal-stretch: 1;
                min-height: 440px;
                border-radius: 8px;
                border-color: color-border;
                background: color-surface;

                HorizontalBox {
                    padding: 28px;
                    spacing: 28px;

                    Rectangle {
                        width: 390px;
                        background: color-surface-alt;
                        border-radius: 8px;

                        VerticalBox {
                            padding: 28px;
                            spacing: 18px;
                            Image { source: @image-url("assets/app_icon.jpg"); width: 58px; height: 58px; image-fit: cover; }
                            Text { text: t-auth-required-title; font-size: 30px; font-weight: 700; color: color-text-primary; wrap: word-wrap; }
                            Text { text: t-auth-required-subtitle; font-size: 14px; color: color-text-secondary; wrap: word-wrap; }
                            StatusPill { text: t-auth-demo-hint; bg: #eff6ff; fg: color-accent; }
                            Text { text: account-status; font-size: 12px; color: color-text-muted; wrap: word-wrap; }
                            Rectangle { vertical-stretch: 1; }
                            Text { text: t-auth-api-hint; font-size: 11px; color: color-text-muted; wrap: word-wrap; }
                        }
                    }

                    VerticalBox {
                        horizontal-stretch: 1;
                        spacing: 12px;

                        HorizontalBox {
                            spacing: 10px;
                            ComboBox {
                                width: 132px;
                                current-value <=> ui-locale;
                                model: ["en", "zh-Hans", "zh-Hant", "fr", "ja-JP", "de"];
                                selected(_) => { apply-appearance-clicked(ui-locale, ui-theme); }
                            }
                            ComboBox {
                                width: 132px;
                                current-value <=> ui-theme;
                                model: ["default", "blue", "green", "purple", "orange", "dark"];
                                selected(_) => { apply-appearance-clicked(ui-locale, ui-theme); }
                            }
                        }

                        Text { text: t-account-sign-in-register; font-size: 22px; font-weight: 700; color: color-text-primary; }
                        LineEdit { placeholder-text: t-settings-api-base-url-placeholder; text <=> api-base-url; }
                        LineEdit { placeholder-text: t-account-email; text <=> login-email; }
                        LineEdit { placeholder-text: t-account-password; text <=> login-password; }

                        HorizontalBox {
                            spacing: 10px;
                            Button {
                                text: is-account-busy ? t-account-signing-in : t-account-login;
                                primary: true;
                                enabled: !is-account-busy && api-base-url != "" && login-email != "";
                                clicked => {
                                    is-account-busy = true;
                                    login-clicked(api-base-url, login-email, login-password);
                                    toast-message = t-account-signing-in;
                                    toast-level = "info";
                                    toast-visible = true;
                                }
                            }
                            Button {
                                text: is-account-busy ? t-account-registering : t-account-register;
                                enabled: !is-account-busy && api-base-url != "" && login-email != "";
                                clicked => {
                                    is-account-busy = true;
                                    register-clicked(api-base-url, login-email, login-password);
                                    toast-message = t-account-registering;
                                    toast-level = "info";
                                    toast-visible = true;
                                }
                            }
                            Button {
                                text: t-account-refresh;
                                enabled: !is-account-busy && api-base-url != "";
                                clicked => {
                                    is-account-busy = true;
                                    refresh-login-clicked(api-base-url);
                                }
                            }
                        }

                        if is-account-busy: ProgressIndicator { progress: 0.5; }
                        Text { text: account-status + "\n" + usage-status; font-size: 12px; color: color-text-secondary; wrap: word-wrap; }
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }
        }
    }

    if is-signed-in: HorizontalBox {
        spacing: 0px;

        Rectangle {
            width: 248px;
            background: color-surface-alt;
            border-color: color-border;

            VerticalBox {
                padding: 18px;
                spacing: 16px;

                HorizontalBox {
                    spacing: 10px;
                    Image { source: @image-url("assets/app_icon.jpg"); width: 38px; height: 38px; image-fit: cover; }
                    VerticalBox {
                        spacing: 1px;
                        Text { text: "Tex2Doc"; font-size: 20px; font-weight: 700; color: color-text-primary; }
                        Text { text: "Commercial workspace"; font-size: 11px; color: color-text-muted; overflow: elide; }
                    }
                }

                NavButton { label: t-common-account; detail: account-tier; selected: selected-page == 0; accent: color-accent; text-primary: color-text-primary; text-muted: color-text-muted; clicked => { selected-page = 0; } }
                NavButton { label: t-nav-recharge; detail: t-nav-quota-billing; selected: selected-page == 1; accent: color-accent; text-primary: color-text-primary; text-muted: color-text-muted; clicked => { selected-page = 1; } }
                NavButton { label: t-tab-convert; detail: t-nav-cloud-engine; selected: selected-page == 2; accent: color-accent; text-primary: color-text-primary; text-muted: color-text-muted; clicked => { selected-page = 2; } }
                NavButton { label: t-nav-conversion-records; detail: t-nav-jobs-reports; selected: selected-page == 3; accent: color-accent; text-primary: color-text-primary; text-muted: color-text-muted; clicked => { selected-page = 3; } }
                NavButton { label: t-nav-recharge-records; detail: t-nav-mock-payment-history; selected: selected-page == 4; accent: color-accent; text-primary: color-text-primary; text-muted: color-text-muted; clicked => { selected-page = 4; } }
                NavButton { label: t-tab-feedback; detail: t-nav-jobs-reports; selected: selected-page == 5; accent: color-accent; text-primary: color-text-primary; text-muted: color-text-muted; clicked => { selected-page = 5; } }

                Rectangle { vertical-stretch: 1; }

                SectionPanel {
                    title: is-signed-in ? account-display-name : "Guest";
                    subtitle: is-signed-in ? usage-status : account-status;
                    surface: color-surface;
                    border: color-border;
                    text-primary: color-text-primary;
                    text-muted: color-text-muted;
                }
            }
        }

        VerticalBox {
            spacing: 0px;

            Rectangle {
                height: 64px;
                background: color-surface;
                border-color: color-border;

                HorizontalBox {
                    padding-left: 22px;
                    padding-right: 22px;
                    spacing: 14px;

                    VerticalBox {
                        horizontal-stretch: 1;
                        spacing: 1px;
                        Text {
                            text: selected-page == 0 ? t-account-overview-title : (selected-page == 1 ? t-recharge-title : (selected-page == 2 ? t-convert-cloud-convert : (selected-page == 3 ? t-records-conversion-title : (selected-page == 4 ? t-records-recharge-title : t-tab-feedback))));
                            font-size: 20px;
                            font-weight: 700;
                            color: color-text-primary;
                            vertical-alignment: bottom;
                        }
                        Text {
                            text: app-version == "" ? "LaTeX to DOCX commercial workspace" : "Version " + app-version;
                            font-size: 11px;
                            color: color-text-muted;
                            vertical-alignment: top;
                        }
                    }

                    ComboBox {
                        width: 112px;
                        current-value <=> ui-locale;
                        model: ["en", "zh-Hans", "zh-Hant", "fr", "ja-JP", "de"];
                        selected(_) => { apply-appearance-clicked(ui-locale, ui-theme); }
                    }

                    ComboBox {
                        width: 112px;
                        current-value <=> ui-theme;
                        model: ["default", "blue", "green", "purple", "orange", "dark"];
                        selected(_) => { apply-appearance-clicked(ui-locale, ui-theme); }
                    }

                    Rectangle {
                        width: 38px;
                        height: 38px;
                        border-radius: 19px;
                        background: is-signed-in ? color-accent : color-border;

                        Text {
                            text: is-signed-in ? "T" : "?";
                            color: #ffffff;
                            font-size: 16px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea { clicked => { account-menu-open = !account-menu-open; } }
                    }
                }
            }

            Rectangle {
                background: color-window-bg;
                horizontal-stretch: 1;
                vertical-stretch: 1;

                if selected-page == 0: Rectangle {
                    background: color-window-bg;
                    VerticalBox {
                        padding: 22px;
                        spacing: 16px;

                        HorizontalBox {
                            spacing: 14px;
                            MetricTile { label: t-account-plan; value: account-tier; note: t-account-active-subscription; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-accent; }
                            MetricTile { label: "Remaining"; value: "" + quota-remaining; note: t-common-quota; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-success; }
                            MetricTile { label: t-account-status; value: t-account-signed-in-short; note: account-status; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-warning; }
                        }

                        SectionPanel { title: t-account-sign-in-register; subtitle: "Use the commercial API account to unlock cloud conversion, quota records, and billing operations."; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; }

                        Rectangle {
                            border-radius: 8px;
                            border-color: color-border;
                            background: color-surface;
                            VerticalBox {
                                padding: 18px;
                                spacing: 10px;
                                LineEdit { placeholder-text: t-settings-api-base-url-placeholder; text <=> api-base-url; }
                                LineEdit { placeholder-text: t-account-email; text <=> login-email; }
                                LineEdit { placeholder-text: t-account-password; text <=> login-password; }
                                HorizontalBox {
                                    spacing: 10px;
                                    Button { text: is-account-busy ? t-account-signing-in : t-account-login; primary: true; enabled: !is-account-busy && api-base-url != "" && login-email != ""; clicked => { is-account-busy = true; login-clicked(api-base-url, login-email, login-password); toast-message = "Signing in..."; toast-level = "info"; toast-visible = true; } }
                                    Button { text: is-account-busy ? t-account-registering : t-account-register; enabled: !is-account-busy && api-base-url != "" && login-email != ""; clicked => { is-account-busy = true; register-clicked(api-base-url, login-email, login-password); toast-message = "Registering..."; toast-level = "info"; toast-visible = true; } }
                                    Button { text: t-account-refresh; enabled: api-base-url != ""; clicked => { is-account-busy = true; refresh-login-clicked(api-base-url); } }
                                    Button { text: t-account-logout; enabled: is-signed-in; clicked => { logout-clicked(); toast-message = "Signed out."; toast-level = "info"; toast-visible = true; } }
                                    Button { text: t-account-refresh-usage; enabled: is-signed-in && api-base-url != ""; clicked => { refresh-usage-clicked(api-base-url); } }
                                }
                                Text { text: account-status + "\n" + usage-status; font-size: 12px; color: color-text-secondary; wrap: word-wrap; }
                            }
                        }
                    }
                }

                if selected-page == 1: Rectangle {
                    background: color-window-bg;
                    VerticalBox {
                        padding: 22px;
                        spacing: 16px;

                        SectionPanel { title: t-recharge-title; subtitle: t-recharge-subtitle; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; }

                        HorizontalBox {
                            spacing: 14px;
                            MetricTile { label: "Current plan"; value: account-tier; note: billing-plan-id; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-accent; }
                            MetricTile { label: "Quota"; value: "" + quota-remaining + " / " + quota-total; note: is-signed-in ? "Cloud conversions" : "Sign in required"; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-success; }
                            MetricTile { label: "Billing"; value: is-billing-busy ? "Working" : "Ready"; note: billing-status; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-warning; }
                        }

                        Rectangle {
                            border-radius: 8px;
                            border-color: color-border;
                            background: color-surface;
                            VerticalBox {
                                padding: 18px;
                                spacing: 12px;
                                Text { text: t-recharge-by-count; font-size: 16px; font-weight: 700; color: color-text-primary; }
                                HorizontalBox {
                                    spacing: 10px;
                                    LineEdit { placeholder-text: "T2D-XXXX-XXXX-XXXX-XX"; text <=> redeem-code; enabled: !is-billing-busy; horizontal-stretch: 1; }
                                    Button { text: t-recharge-mock-pay; primary: true; enabled: api-base-url != "" && redeem-code != "" && !is-billing-busy; clicked => { is-billing-busy = true; billing-status = "Redeeming code..."; redeem-code-clicked(api-base-url, redeem-code); } }
                                }
                                Text { text: t-recharge-by-date; font-size: 16px; font-weight: 700; color: color-text-primary; }
                                HorizontalBox {
                                    spacing: 10px;
                                    StatusPill { text: "count_3"; bg: #eff6ff; fg: color-accent; }
                                    StatusPill { text: "count_10"; bg: #ecfdf5; fg: color-success; }
                                    StatusPill { text: "count_30"; bg: #fffbeb; fg: color-warning; }
                                }
                                HorizontalBox {
                                    spacing: 10px;
                                    Button { text: t-billing-plans; enabled: api-base-url != ""; clicked => { is-billing-busy = true; show-plans-clicked(api-base-url); } }
                                    Button { text: t-billing-portal; enabled: api-base-url != ""; clicked => { is-billing-busy = true; billing-portal-clicked(api-base-url); } }
                                    Button { text: "Recharge Records"; enabled: is-signed-in && api-base-url != ""; clicked => { selected-page = 4; is-billing-busy = true; refresh-recharge-records-clicked(api-base-url); } }
                                }
                                Text { text: billing-status; font-size: 12px; color: color-text-secondary; wrap: word-wrap; }
                            }
                        }
                    }
                }

                if selected-page == 2: Rectangle {
                    background: color-window-bg;
                    VerticalBox {
                        padding: 22px;
                        spacing: 14px;

                        SectionPanel { title: t-convert-cloud-convert; subtitle: "Upload a complete LaTeX project, choose the main TeX file, and run the semantic conversion engine."; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; }

                        Rectangle {
                            border-radius: 8px;
                            border-color: color-border;
                            background: color-surface;
                            VerticalBox {
                                padding: 18px;
                                spacing: 10px;

                                HorizontalBox {
                                    spacing: 8px;
                                    LineEdit { placeholder-text: t-convert-project-placeholder; text <=> project-path; }
                                    Button { text: t-convert-folder; enabled: !is-converting; clicked => { choose-project-folder-clicked(project-path, output-path); } }
                                    Button { text: t-convert-zip; enabled: !is-converting; clicked => { choose-project-zip-clicked(project-path, output-path); } }
                                }

                                LineEdit { placeholder-text: t-convert-main-tex-placeholder; text <=> main-tex; }

                                HorizontalBox {
                                    spacing: 10px;
                                    ComboBox { current-value <=> detected-profile; model: ["auto", "generic-article", "tacl", "cvpr", "nature", "springer", "jos-paper", "chinese-academic"]; }
                                    ComboBox { current-value <=> quality-level; model: ["preview", "standard", "strict"]; }
                                    Switch { text: t-convert-cloud; checked <=> use-cloud-engine; enabled: is-signed-in; }
                                }

                                HorizontalBox {
                                    spacing: 8px;
                                    LineEdit { placeholder-text: t-convert-output-placeholder; text <=> output-path; }
                                    Button { text: t-convert-save-as; clicked => { choose-output-clicked(output-path); } }
                                }

                                HorizontalBox {
                                    spacing: 10px;
                                    Button { text: t-convert-detect-profile; enabled: project-path != "" && !is-converting; clicked => { status-text = t-convert-detecting-profile + project-path; detect-profile-clicked(project-path); } }
                                    Button {
                                        text: is-converting ? t-convert-converting : (use-cloud-engine ? t-convert-cloud-convert : t-convert-convert);
                                        primary: true;
                                        enabled: !is-converting && project-path != "" && output-path != "" && (!use-cloud-engine || is-signed-in);
                                        clicked => {
                                            is-converting = true;
                                            conversion-progress = 0.15;
                                            if use-cloud-engine {
                                                cloud-convert-clicked(api-base-url, project-path, main-tex, detected-profile, quality-level, output-path);
                                            } else {
                                                convert-clicked(project-path, detected-profile, quality-level, output-path);
                                            }
                                        }
                                    }
                                    Button { text: t-convert-open-output; enabled: output-path != ""; clicked => { open-output-clicked(output-path); } }
                                    Button { text: t-convert-open-report; enabled: output-path != ""; clicked => { open-report-clicked(output-path); } }
                                }

                                ProgressIndicator { progress: is-converting ? conversion-progress : 0.0; }
                                Text { text: status-text == "" ? t-convert-ready : status-text; font-size: 12px; color: color-text-secondary; wrap: word-wrap; }
                            }
                        }

                        HorizontalBox {
                            spacing: 14px;
                            MetricTile { label: t-common-compatibility; value: compatibility-score; note: "Profile " + detected-profile; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-accent; }
                            MetricTile { label: "Quality"; value: quality-status; note: quality-level; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-success; }
                            MetricTile { label: t-common-confidence; value: profile-confidence; note: t-convert-detected; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-warning; }
                        }
                    }
                }

                if selected-page == 3: Rectangle {
                    background: color-window-bg;
                    VerticalBox {
                        padding: 22px;
                        spacing: 14px;
                        SectionPanel { title: t-records-conversion-title; subtitle: t-records-conversion-subtitle; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; }
                        Rectangle {
                            border-radius: 8px;
                            border-color: color-border;
                            background: color-surface;
                            VerticalBox {
                                padding: 14px;
                                spacing: 8px;
                                HorizontalBox {
                                    spacing: 10px;
                                    Button { text: "Query Cloud Records"; enabled: is-signed-in && api-base-url != "" && !is-billing-busy; clicked => { is-billing-busy = true; refresh-conversion-records-clicked(api-base-url); } }
                                    Text { text: cloud-conversion-records.length > 0 ? "Cloud conversion records" : "Local conversion records"; font-size: 12px; color: color-text-muted; }
                                }
                                Rectangle {
                                    height: 30px;
                                    background: color-surface-alt;
                                    HorizontalBox {
                                        padding: 8px;
                                        spacing: 10px;
                                        Text { text: "Status"; width: 96px; font-size: 11px; font-weight: 700; color: color-text-primary; }
                                        Text { text: "Main/Input"; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: color-text-primary; }
                                        Text { text: "Profile"; width: 110px; font-size: 11px; font-weight: 700; color: color-text-primary; }
                                        Text { text: "Updated"; width: 138px; font-size: 11px; font-weight: 700; color: color-text-primary; }
                                        Text { text: "Error"; width: 150px; font-size: 11px; font-weight: 700; color: color-text-primary; }
                                    }
                                }
                                if cloud-conversion-records.length == 0 && job-history.length == 0: Text { text: recent-jobs; font-size: 12px; color: color-text-secondary; wrap: word-wrap; }
                                ListView {
                                    visible: cloud-conversion-records.length > 0;
                                    height: 390px;
                                    for row[idx] in cloud-conversion-records: Rectangle {
                                        min-height: 42px;
                                        background: Math.mod(idx, 2) == 0 ? color-surface : color-surface-alt;
                                        HorizontalBox {
                                            padding: 8px;
                                            spacing: 10px;
                                            Text { text: row.status; width: 96px; font-size: 11px; color: row.status == "Completed" ? color-success : (row.status == "Failed" ? color-danger : color-accent); overflow: elide; }
                                            Text { text: row.main-tex; horizontal-stretch: 1; font-size: 11px; color: color-text-secondary; overflow: elide; }
                                            Text { text: row.profile; width: 110px; font-size: 11px; color: color-text-muted; overflow: elide; }
                                            Text { text: row.updated-at; width: 138px; font-size: 10px; color: color-text-muted; overflow: elide; }
                                            Text { text: row.error; width: 150px; font-size: 10px; color: row.error == "-" ? color-text-muted : color-danger; overflow: elide; }
                                        }
                                    }
                                }
                                ListView {
                                    visible: cloud-conversion-records.length == 0 && job-history.length > 0;
                                    height: 390px;
                                    for row[idx] in job-history: Rectangle {
                                        min-height: 46px;
                                        background: Math.mod(idx, 2) == 0 ? color-surface : color-surface-alt;
                                        HorizontalBox {
                                            padding: 8px;
                                            spacing: 10px;
                                            Text { text: row.status; width: 96px; font-size: 11px; color: row.status == "Succeeded" ? color-success : (row.status == "Failed" ? color-danger : color-accent); }
                                            Text { text: row.input; horizontal-stretch: 1; font-size: 11px; color: color-text-secondary; overflow: elide; }
                                            Text { text: row.kind; width: 110px; font-size: 11px; color: color-text-muted; overflow: elide; }
                                            Text { text: row.opened-at; width: 138px; font-size: 10px; color: color-text-muted; overflow: elide; }
                                            Text { text: row.error == "" ? "-" : row.error; width: 150px; font-size: 10px; color: row.error == "" ? color-text-muted : color-danger; overflow: elide; }
                                            Button { text: "Remove"; clicked => { remove-job-clicked(row.id); } }
                                        }
                                    }
                                }
                                HorizontalBox {
                                    spacing: 10px;
                                    Button { text: t-history-open-output; enabled: output-path != ""; clicked => { open-output-clicked(output-path); } }
                                    Button { text: t-history-open-report; enabled: output-path != ""; clicked => { open-report-clicked(output-path); } }
                                    Button { text: t-history-export-diagnostics; clicked => { export-diagnostics-clicked(project-path, output-path, api-base-url, detected-profile, quality-level, status-text, recent-jobs, update-status); } }
                                    Button { text: "Clear"; enabled: job-history.length > 0; clicked => { clear-jobs-clicked(); } }
                                }
                            }
                        }
                    }
                }

                if selected-page == 4: Rectangle {
                    background: color-window-bg;
                    VerticalBox {
                        padding: 22px;
                        spacing: 14px;
                        SectionPanel { title: t-records-recharge-title; subtitle: t-records-recharge-subtitle; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; }
                        Rectangle {
                            border-radius: 8px;
                            border-color: color-border;
                            background: color-surface;
                            VerticalBox {
                                padding: 18px;
                                spacing: 12px;
                                HorizontalBox {
                                    spacing: 12px;
                                    StatusPill { text: billing-plan-id; bg: #eff6ff; fg: color-accent; }
                                    StatusPill { text: is-billing-busy ? "processing" : "idle"; bg: #ecfdf5; fg: color-success; }
                                    StatusPill { text: account-tier; bg: #fffbeb; fg: color-warning; }
                                    Button { text: "Query Records"; enabled: is-signed-in && api-base-url != "" && !is-billing-busy; clicked => { is-billing-busy = true; refresh-recharge-records-clicked(api-base-url); } }
                                }
                                Rectangle {
                                    height: 30px;
                                    background: color-surface-alt;
                                    HorizontalBox {
                                        padding: 8px;
                                        spacing: 10px;
                                        Text { text: "Type"; width: 90px; font-size: 11px; font-weight: 700; color: color-text-primary; }
                                        Text { text: "Package / Code"; horizontal-stretch: 1; font-size: 11px; font-weight: 700; color: color-text-primary; }
                                        Text { text: "Qty"; width: 58px; font-size: 11px; font-weight: 700; color: color-text-primary; }
                                        Text { text: "Status"; width: 92px; font-size: 11px; font-weight: 700; color: color-text-primary; }
                                        Text { text: "Provider"; width: 118px; font-size: 11px; font-weight: 700; color: color-text-primary; }
                                        Text { text: "Created"; width: 138px; font-size: 11px; font-weight: 700; color: color-text-primary; }
                                    }
                                }
                                if recharge-records.length == 0: Text { text: billing-status == "--" ? t-records-no-recharge : billing-status; font-size: 13px; color: color-text-secondary; wrap: word-wrap; }
                                ListView {
                                    visible: recharge-records.length > 0;
                                    height: 390px;
                                    for row[idx] in recharge-records: Rectangle {
                                        min-height: 42px;
                                        background: Math.mod(idx, 2) == 0 ? color-surface : color-surface-alt;
                                        HorizontalBox {
                                            padding: 8px;
                                            spacing: 10px;
                                            Text { text: row.kind; width: 90px; font-size: 11px; color: color-text-secondary; overflow: elide; }
                                            Text { text: row.package; horizontal-stretch: 1; font-size: 11px; color: color-text-secondary; overflow: elide; }
                                            Text { text: row.quantity; width: 58px; font-size: 11px; color: color-text-muted; overflow: elide; }
                                            Text { text: row.status; width: 92px; font-size: 11px; color: row.status == "paid" || row.status == "redeemed" ? color-success : color-warning; overflow: elide; }
                                            Text { text: row.provider; width: 118px; font-size: 10px; color: color-text-muted; overflow: elide; }
                                            Text { text: row.created-at; width: 138px; font-size: 10px; color: color-text-muted; overflow: elide; }
                                        }
                                    }
                                }
                                Text { text: "Account: " + account-display-name + " | Quota: " + quota-remaining + " / " + quota-total; font-size: 12px; color: color-text-muted; wrap: word-wrap; }
                                Button { text: "Go to Recharge"; clicked => { selected-page = 1; } }
                            }
                        }
                    }
                }

                if selected-page == 5: Rectangle {
                    background: color-window-bg;
                    VerticalBox {
                        padding: 22px;
                        spacing: 14px;
                        SectionPanel { title: t-tab-feedback; subtitle: "Submit issues or feature requests linked to a specific conversion record."; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; }
                        Rectangle {
                            border-radius: 8px;
                            border-color: color-border;
                            background: color-surface;
                            VerticalBox {
                                padding: 14px;
                                spacing: 8px;
                                HorizontalBox {
                                    spacing: 10px;
                                    Text { text: "Feedback Threads (" + feedback-threads.length + ")"; font-size: 14px; font-weight: 700; color: color-text-primary; }
                                }
                                if feedback-threads.length == 0: Text { text: "No feedback threads yet. Submit your first issue or request from the Flutter app."; font-size: 12px; color: color-text-muted; wrap: word-wrap; }
                                ListView {
                                    visible: feedback-threads.length > 0;
                                    height: 390px;
                                    for row[idx] in feedback-threads: Rectangle {
                                        min-height: 52px;
                                        border-radius: 6px;
                                        border-color: color-border;
                                        background: Math.mod(idx, 2) == 0 ? color-surface : color-surface-alt;
                                        VerticalBox {
                                            padding: 10px;
                                            spacing: 4px;
                                            HorizontalBox {
                                                spacing: 8px;
                                                StatusPill { text: row.feedback-type; bg: row.feedback-type == "issue" ? #fef2f2 : #eff6ff; fg: row.feedback-type == "issue" ? color-danger : color-accent; }
                                                StatusPill { text: row.status; bg: row.status == "open" ? #fef2f2 : (row.status == "resolved" ? #ecfdf5 : #eff6ff); fg: row.status == "open" ? color-danger : (row.status == "resolved" ? color-success : color-warning); }
                                                StatusPill { text: row.priority; bg: row.priority == "high" || row.priority == "urgent" ? #fef2f2 : #eff6ff; fg: row.priority == "high" || row.priority == "urgent" ? color-danger : color-text-muted; }
                                                Text { text: row.title; horizontal-stretch: 1; font-size: 13px; font-weight: 600; color: color-text-primary; overflow: elide; }
                                            }
                                            Text { text: "Job: " + row.conversion-job-id + " | Msgs: " + row.message-count + " | Updated: " + row.latest-message-at; font-size: 11px; color: color-text-muted; overflow: elide; }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    if account-menu-open: Rectangle {
        x: root.width - 230px;
        y: 58px;
        width: 208px;
        height: 144px;
        border-radius: 8px;
        border-color: color-border;
        background: color-surface;
        VerticalBox {
            padding: 10px;
            spacing: 6px;
            Button { text: t-dialog-view-profile; clicked => { profile-dialog-open = true; account-menu-open = false; } }
            Button { text: t-dialog-change-password; enabled: is-signed-in; clicked => { password-dialog-open = true; account-menu-open = false; } }
            Button { text: t-account-logout; enabled: is-signed-in; clicked => { logout-clicked(); account-menu-open = false; } }
        }
    }

    if profile-dialog-open: Rectangle {
        x: (root.width - 420px) / 2;
        y: 132px;
        width: 420px;
        height: 260px;
        border-radius: 8px;
        border-color: color-border;
        background: color-surface;
        VerticalBox {
            padding: 22px;
            spacing: 12px;
            Text { text: t-dialog-account-details; font-size: 20px; font-weight: 700; color: color-text-primary; }
            Text { text: "Email: " + login-email + "\nDisplay: " + account-display-name + "\nPlan: " + account-tier + "\nQuota: " + quota-remaining + " / " + quota-total; color: color-text-secondary; font-size: 13px; wrap: word-wrap; }
            Button { text: t-dialog-close; clicked => { profile-dialog-open = false; } }
        }
    }

    if password-dialog-open: Rectangle {
        x: (root.width - 420px) / 2;
        y: 120px;
        width: 420px;
        height: 318px;
        border-radius: 8px;
        border-color: color-border;
        background: color-surface;
        VerticalBox {
            padding: 22px;
            spacing: 10px;
            Text { text: t-dialog-change-password; font-size: 20px; font-weight: 700; color: color-text-primary; }
            LineEdit { placeholder-text: "Current password"; text <=> password-old; }
            LineEdit { placeholder-text: "New password"; text <=> password-new; }
            LineEdit { placeholder-text: "Confirm new password"; text <=> password-confirm; }
            Text { text: password-new != password-confirm ? "Passwords do not match." : ""; color: color-danger; font-size: 12px; }
            HorizontalBox {
                spacing: 10px;
                Button { text: t-dialog-cancel; clicked => { password-dialog-open = false; } }
                Button {
                    text: t-dialog-confirm;
                    primary: true;
                    enabled: password-new == password-confirm && password-new != "";
                    clicked => {
                        password-dialog-open = false;
                        toast-message = "Password changed successfully.";
                        toast-level = "success";
                        toast-visible = true;
                    }
                }
            }
        }
    }

    if toast-visible: Rectangle {
        x: root.width - 360px;
        y: root.height - 88px;
        width: 330px;
        height: 54px;
        border-radius: 8px;
        background: toast-level == "success" ? #ecfdf5 : (toast-level == "error" ? #fef2f2 : #eff6ff);
        border-color: toast-level == "success" ? color-success : (toast-level == "error" ? color-danger : color-accent);
        HorizontalBox {
            padding: 12px;
            spacing: 10px;
            Text { text: toast-message; horizontal-stretch: 1; font-size: 12px; color: color-text-primary; overflow: elide; vertical-alignment: center; }
            Button { text: "OK"; clicked => { toast-visible = false; } }
        }
    }
}
