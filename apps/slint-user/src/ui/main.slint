import {
    Button,
    VerticalBox,
    HorizontalBox,
    LineEdit,
    TextEdit,
    ComboBox,
    ProgressIndicator,
    ListView,
    Switch,
} from "std-widgets.slint";
import { PlanEntry, JobRow, RechargeRow, CloudConversionRow, ConversionMode, FeedbackThreadRow } from "types.slint";

component NavButton inherits Rectangle {
    in property <string> label;
    in property <string> detail;
    in property <bool> selected: false;
    in property <color> accent: #2563eb;
    in property <color> text-primary: #172033;
    in property <color> text-muted: #6b778c;
    callback clicked();

    height: 54px;
    border-radius: 8px;
    background: selected ? #eff6ff : #00000000;

    TouchArea { clicked => { root.clicked(); } }

    HorizontalBox {
        padding-left: 14px;
        padding-right: 12px;
        spacing: 10px;

        Rectangle {
            width: 4px;
            height: 28px;
            border-radius: 2px;
            background: root.selected ? root.accent : #00000000;
        }

        VerticalBox {
            vertical-stretch: 1;
            spacing: 2px;
            Text {
                text: root.label;
                font-size: 14px;
                font-weight: root.selected ? 700 : 500;
                color: root.selected ? root.accent : root.text-primary;
                vertical-alignment: bottom;
            }
            Text {
                text: root.detail;
                font-size: 11px;
                color: root.text-muted;
                overflow: elide;
                vertical-alignment: top;
            }
        }
    }
}

component MetricTile inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> note;
    in property <color> surface: #ffffff;
    in property <color> border: #d7dee8;
    in property <color> text-primary: #172033;
    in property <color> text-muted: #6b778c;
    in property <color> accent: #2563eb;

    min-height: 86px;
    border-radius: 8px;
    border-color: border;
    background: surface;

    VerticalBox {
        padding: 14px;
        spacing: 5px;
        Text { text: root.label; font-size: 11px; color: root.text-muted; }
        Text { text: root.value; font-size: 22px; font-weight: 700; color: root.text-primary; overflow: elide; }
        Text { text: root.note; font-size: 11px; color: root.accent; overflow: elide; }
    }
}

component SectionPanel inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <color> surface: #ffffff;
    in property <color> border: #d7dee8;
    in property <color> text-primary: #172033;
    in property <color> text-muted: #6b778c;

    border-radius: 8px;
    border-color: border;
    background: surface;

    VerticalBox {
        padding: 18px;
        spacing: 4px;
        Text { text: root.title; font-size: 18px; font-weight: 700; color: root.text-primary; }
        Text { text: root.subtitle; font-size: 12px; color: root.text-muted; wrap: word-wrap; }
    }
}

component StatusPill inherits Rectangle {
    in property <string> text;
    in property <color> bg: #eff6ff;
    in property <color> fg: #2563eb;

    height: 26px;
    min-width: 86px;
    border-radius: 999px;
    background: bg;

    Text {
        text: root.text;
        color: root.fg;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component MainWindow inherits Window {
    title: t-app-title-signed-out + " " + app-version;
    icon: @image-url("assets/app_icon.jpg");
    preferred-width: 1220px;
    preferred-height: 790px;
    background: color-window-bg;

    in-out property <int> selected-page: 0;
    in-out property <bool> account-menu-open: false;
    in-out property <bool> profile-dialog-open: false;
    in-out property <bool> password-dialog-open: false;
    in-out property <string> password-old;
    in-out property <string> password-new;
    in-out property <string> password-confirm;
    in-out property <bool> toast-visible: false;
    in-out property <string> toast-message: "";
    in-out property <string> toast-level: "info";

    in-out property <string> project-path;
    in-out property <string> api-base-url;
    in-out property <string> login-email: "demo@example.com";
    in-out property <string> login-password: "secret";
    in-out property <string> account-status: "Not signed in.";
    in-out property <string> usage-status: "--";
    in-out property <bool> is-signed-in: false;
    in-out property <bool> is-account-busy: false;
    in-out property <bool> is-billing-busy: false;
    in-out property <string> account-display-name: "Guest";
    in-out property <string> account-tier: "free";
    in-out property <int> quota-remaining: 0;
    in-out property <int> quota-total: 0;
    in-out property <string> billing-plan-id: "pro";
    in-out property <string> billing-status: "--";
    in-out property <string> redeem-code: "";
    in-out property <[PlanEntry]> plan-catalog;
    in-out property <[RechargeRow]> recharge-records;
    in-out property <[CloudConversionRow]> cloud-conversion-records;
    in-out property <[FeedbackThreadRow]> feedback-threads;
    in-out property <int> current-plan-index: 0;
    in-out property <string> update-channel: "stable";
    in-out property <string> update-status: "--";
    in-out property <string> ui-locale: "en";
    in-out property <string> ui-theme: "default";
    in-out property <string> app-version: "";
    in-out property <string> detected-profile: "auto";
    in-out property <string> main-tex;
    in-out property <string> quality-level: "standard";
    in-out property <string> output-path;
    in-out property <string> status-text: "";
    in-out property <bool> is-converting: false;
    in-out property <float> conversion-progress: 0.0;
    in-out property <bool> use-cloud-engine: true;
    in-out property <string> compatibility-score: "--";
    in-out property <float> compatibility-progress: 0.0;
    in-out property <string> quality-status: "--";
    in-out property <float> quality-progress: 0.0;
    in-out property <string> profile-confidence: "--";
    in-out property <float> profile-confidence-progress: 0.0;
    in-out property <string> recent-jobs: "No recent jobs.";
    in-out property <[JobRow]> job-history;
    in-out property <int> selected-job-index: -1;
    in-out property <bool> settings-dirty: false;
    in-out property <string> settings-saved-at: "";
    in-out property <string> settings-panel-state: "idle";

    in-out property <color> color-window-bg: #f6f8fb;
    in-out property <color> color-surface: #ffffff;
    in-out property <color> color-surface-alt: #f1f5f9;
    in-out property <color> color-border: #d7dee8;
    in-out property <color> color-text-primary: #172033;
    in-out property <color> color-text-secondary: #42526b;
    in-out property <color> color-text-muted: #6b778c;
    in-out property <color> color-accent: #2563eb;
    in-out property <color> color-success: #0f8a5f;
    in-out property <color> color-warning: #b7791f;
    in-out property <color> color-danger: #c2413a;

    in-out property <string> t-tab-convert: "Convert";
    in-out property <string> t-tab-settings: "Settings";
    in-out property <string> t-tab-account: "Account";
    in-out property <string> t-tab-billing: "Billing";
    in-out property <string> t-tab-history: "History";
    in-out property <string> t-tab-feedback: "Feedback";
    in-out property <string> t-app-title-signed-out: "Tex2Doc Desktop";
    in-out property <string> t-common-account: "Account";
    in-out property <string> t-common-quota: "Quota";
    in-out property <string> t-common-compatibility: "Compatibility";
    in-out property <string> t-common-confidence: "Confidence";
    in-out property <string> t-convert-engine: "Engine";
