    in-out property <string> t-convert-cloud: "Cloud";
    in-out property <string> t-convert-cloud-requires-sign-in: "Cloud engine requires sign-in.";
    in-out property <string> t-convert-project: "Project";
    in-out property <string> t-convert-project-placeholder: "TeX project path or project zip...";
    in-out property <string> t-convert-folder: "Folder";
    in-out property <string> t-convert-zip: "Zip";
    in-out property <string> t-convert-main-tex-placeholder: "Main TeX for cloud conversion (optional, e.g. main.tex)...";
    in-out property <string> t-convert-options: "Options";
    in-out property <string> t-convert-profile: "Profile";
    in-out property <string> t-convert-quality: "Quality";
    in-out property <string> t-convert-output: "Output";
    in-out property <string> t-convert-output-placeholder: "Output DOCX path...";
    in-out property <string> t-convert-save-as: "Save As";
    in-out property <string> t-convert-detect-profile: "Detect Profile";
    in-out property <string> t-convert-detecting-profile: "[...] Detecting profile for: ";
