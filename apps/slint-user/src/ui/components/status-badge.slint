import { DesignTokens } from "../tokens.slint";

export component StatusBadge inherits Rectangle {
    in property <string> text: "";
    in property <color> background-color: DesignTokens.token-accent-subtle;
    in property <color> text-color: DesignTokens.token-accent;

    background: background-color;
    border-radius: 999px;
    min-width: 64px;
    height: 24px;

    Text {
        text: root.text;
        color: root.text-color;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}
