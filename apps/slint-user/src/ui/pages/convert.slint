import { Button, VerticalBox, HorizontalBox, LineEdit, TextEdit, ComboBox, ProgressIndicator, GroupBox, Switch } from "std-widgets.slint";
import { ConversionMode } from "../types.slint";
import { MetricCard } from "../components/metric-card.slint";
import { AlertBanner } from "../components/alert-banner.slint";

export component ConvertTab inherits Rectangle {
    in-out property <string> project-path;
    in-out property <string> api-base-url;
    in-out property <string> main-tex;
    in-out property <string> detected-profile: "auto";
    in-out property <string> quality-level: "standard";
    in-out property <string> output-path;
    in-out property <bool> is-converting: false;
    in-out property <float> conversion-progress: 0.0;
    in-out property <string> compatibility-score: "--";
    in-out property <float> compatibility-progress: 0.0;
    in-out property <string> quality-status: "--";
    in-out property <float> quality-progress: 0.0;
    in-out property <string> profile-confidence: "--";
    in-out property <float> profile-confidence-progress: 0.0;
    in-out property <string> status-text: "";
    in-out property <ConversionMode> conversion-mode: use-cloud-engine ? ConversionMode.cloud : ConversionMode.local;
    in-out property <bool> is-signed-in: false;
    in-out property <int> quota-remaining: 0;
    in-out property <bool> use-cloud-engine: false;

    in property <color> surface-color: #FFFFFF;
    in property <color> surface-alt-color: #F1F5F9;
    in property <color> border-color-token: #D7DEE8;
    in property <color> text-primary-color: #172033;
    in property <color> text-secondary-color: #42526B;
    in property <color> text-muted-color: #6B778C;
    in property <color> accent-color: #2563EB;
    in property <color> success-color: #0F8A5F;
    in property <color> warning-color: #B7791F;
    in property <color> danger-color: #C2413A;

    in property <string> t-convert-engine: "Engine";
    in property <string> t-convert-local: "Local";
    in property <string> t-convert-cloud: "Cloud";
    in property <string> t-convert-cloud-requires-sign-in: "Cloud engine requires sign-in.";
    in property <string> t-convert-project: "Project";
    in property <string> t-convert-project-placeholder: "TeX project path or project zip...";
    in property <string> t-convert-folder: "Folder";
    in property <string> t-convert-zip: "Zip";
    in property <string> t-convert-main-tex-placeholder: "Main TeX for cloud conversion (optional, e.g. main.tex)...";
    in property <string> t-convert-options: "Options";
    in property <string> t-convert-profile: "Profile";
    in property <string> t-convert-quality: "Quality";
    in property <string> t-convert-output: "Output";
    in property <string> t-convert-output-placeholder: "Output DOCX path...";
    in property <string> t-convert-save-as: "Save As";
    in property <string> t-convert-detect-profile: "Detect Profile";
    in property <string> t-convert-detecting-profile: "[...] Detecting profile for: ";
    in property <string> t-convert-convert: "Convert";
    in property <string> t-convert-cloud-convert: "Cloud Convert";
    in property <string> t-convert-converting: "Converting...";
    in property <string> t-convert-uploading: "Uploading...";
    in property <string> t-convert-reading-source: "[1/3] Reading TeX source...";
    in property <string> t-convert-open-output: "Open Output";
    in property <string> t-convert-open-report: "Open Report";
    in property <string> t-convert-cloud-reason-sign-in: "Sign in to use cloud engine.";
    in property <string> t-convert-cloud-reason-api: "Set API base URL in Settings.";
    in property <string> t-convert-cloud-reason-fields: "Fill project and output paths above.";
    in property <string> t-convert-report: "Report";
    in property <string> t-convert-detected: "detected";
    in property <string> t-convert-status: "Status";
    in property <string> t-convert-ready: "Ready. Enter a project path and click Convert.";
    in property <string> t-common-compatibility: "Compatibility";
    in property <string> t-common-confidence: "Confidence";
    in property <string> t-common-account: "Account";
    in property <string> t-common-quota: "Quota";

    callback choose-project-folder-clicked(string, string);
    callback choose-project-zip-clicked(string, string);
    callback choose-output-clicked(string);
    callback detect-profile-clicked(string);
    callback convert-clicked(string, string, string, string);
    callback cloud-convert-clicked(string, string, string, string, string, string);
    callback open-output-clicked(string);
    callback open-report-clicked(string);

    background: surface-alt-color;

    VerticalBox {
        padding: 16px;
        spacing: 12px;

        AlertBanner {
            message: use-cloud-engine && !is-signed-in
                ? root.t-convert-cloud-reason-sign-in
                : (use-cloud-engine && root.api-base-url == ""
                    ? root.t-convert-cloud-reason-api
                    : (use-cloud-engine && root.quota-remaining <= 0
                        ? "Quota is exhausted. Recharge to continue."
                        : ""));
            background-color: use-cloud-engine && root.quota-remaining <= 0 ? #FEF2F2 : #FFFBEB;
            border-color-token: root.border-color-token;
            text-color: use-cloud-engine && root.quota-remaining <= 0 ? root.danger-color : root.warning-color;
        }

        GroupBox {
            title: root.t-convert-engine;

            HorizontalBox {
                spacing: 12px;

                Button {
                    text: root.t-convert-local;
                    primary: !root.use-cloud-engine;
                    enabled: !root.is-converting;
                    clicked => {
                        root.use-cloud-engine = false;
                        root.conversion-mode = ConversionMode.local;
                    }
                }

                Button {
                    text: root.t-convert-cloud;
                    primary: root.use-cloud-engine;
                    enabled: !root.is-converting && root.is-signed-in;
                    clicked => {
                        root.use-cloud-engine = true;
                        root.conversion-mode = ConversionMode.cloud;
                    }
                }

                Switch {
                    text: root.is-signed-in ? "Cloud ready" : root.t-convert-cloud-requires-sign-in;
                    checked: root.use-cloud-engine;
                    enabled: root.is-signed-in && !root.is-converting;
                    toggled => {
                        root.use-cloud-engine = self.checked;
                        root.conversion-mode = self.checked ? ConversionMode.cloud : ConversionMode.local;
                    }
                }

                Text {
                    text: root.is-signed-in
                        ? root.t-common-account + ": " + root.t-common-quota + " " + root.quota-remaining
                        : root.t-convert-cloud-requires-sign-in;
                    font-size: 12px;
                    color: root.is-signed-in ? root.text-secondary-color : root.danger-color;
                    vertical-alignment: center;
                }
            }
        }

        GroupBox {
            title: root.t-convert-project;

            VerticalBox {
                spacing: 8px;

                HorizontalBox {
                    spacing: 8px;

                    LineEdit {
                        placeholder-text: root.t-convert-project-placeholder;
                        text <=> root.project-path;
                    }

                    Button {
                        text: root.t-convert-folder;
                        enabled: !root.is-converting;
                        clicked => { root.choose-project-folder-clicked(root.project-path, root.output-path); }
                    }

                    Button {
                        text: root.t-convert-zip;
                        enabled: !root.is-converting;
                        clicked => { root.choose-project-zip-clicked(root.project-path, root.output-path); }
                    }
                }

                LineEdit {
                    placeholder-text: root.t-convert-main-tex-placeholder;
                    text <=> root.main-tex;
                    enabled: root.use-cloud-engine;
                }
            }
        }

        GroupBox {
            title: root.t-convert-options;

            HorizontalBox {
                spacing: 16px;

                VerticalBox {
                    Text { text: root.t-convert-profile; font-size: 12px; color: root.text-secondary-color; }
                    ComboBox {
                        current-value <=> root.detected-profile;
                        model: ["auto", "generic-article", "tacl", "cvpr", "nature", "springer", "jos-paper", "chinese-academic"];
                    }
                }

                VerticalBox {
                    Text { text: root.t-convert-quality; font-size: 12px; color: root.text-secondary-color; }
                    ComboBox {
                        current-value <=> root.quality-level;
                        model: ["preview", "standard", "strict"];
                    }
                }

                VerticalBox {
                    horizontal-stretch: 1;
                    Text { text: root.t-convert-output; font-size: 12px; color: root.text-secondary-color; }
                    HorizontalBox {
                        spacing: 8px;
                        LineEdit {
                            placeholder-text: root.t-convert-output-placeholder;
                            text <=> root.output-path;
                        }
                        Button {
                            text: root.t-convert-save-as;
                            enabled: !root.is-converting;
                            clicked => { root.choose-output-clicked(root.output-path); }
                        }
                    }
                }
            }
        }

        HorizontalBox {
            spacing: 8px;

            Button {
                text: root.t-convert-detect-profile;
                enabled: root.project-path != "" && !root.is-converting;
                clicked => {
                    root.status-text = root.t-convert-detecting-profile + root.project-path + "...";
                    root.detect-profile-clicked(root.project-path);
                }
            }

            Button {
                primary: true;
                text: root.is-converting
                    ? (root.use-cloud-engine ? root.t-convert-uploading : root.t-convert-converting)
                    : (root.use-cloud-engine ? root.t-convert-cloud-convert : root.t-convert-convert);
                enabled: root.project-path != "" && root.output-path != "" && !root.is-converting
                    && (!root.use-cloud-engine || (root.api-base-url != "" && root.is-signed-in && root.quota-remaining > 0));
                clicked => {
                    root.is-converting = true;
                    root.conversion-progress = 0.1;
                    if root.use-cloud-engine {
                        root.status-text = "[cloud] Uploading TeX project...";
                        root.cloud-convert-clicked(root.api-base-url, root.project-path, root.main-tex, root.detected-profile, root.quality-level, root.output-path);
                    } else {
                        root.status-text = root.t-convert-reading-source;
                        root.convert-clicked(root.project-path, root.detected-profile, root.quality-level, root.output-path);
                    }
                }
            }

            Button {
                text: root.t-convert-open-output;
                enabled: !root.is-converting && root.output-path != "";
                clicked => { root.open-output-clicked(root.output-path); }
            }

            Button {
                text: root.t-convert-open-report;
                enabled: !root.is-converting && root.output-path != "";
                clicked => { root.open-report-clicked(root.output-path); }
            }
        }

        ProgressIndicator {
            progress: root.conversion-progress;
            visible: root.is-converting;
        }

        GroupBox {
            title: root.t-convert-report;

            HorizontalBox {
                spacing: 10px;

                MetricCard {
                    label: root.t-convert-profile;
                    value: root.detected-profile;
                    caption: root.t-convert-detected;
                    surface-color: root.surface-color;
                    border-color-token: root.border-color-token;
                    text-color: root.text-primary-color;
                    muted-color: root.text-muted-color;
                }

                MetricCard {
                    label: root.t-common-compatibility;
                    value: root.compatibility-score == "--" ? "--" : root.compatibility-score + "%";
                    progress: root.compatibility-progress;
                    show-progress: true;
                    surface-color: root.surface-color;
                    border-color-token: root.border-color-token;
                    muted-color: root.text-muted-color;
                    value-color: root.compatibility-progress >= 0.8 ? root.success-color : (root.compatibility-progress >= 0.5 ? root.warning-color : root.danger-color);
                }

                MetricCard {
                    label: root.t-convert-quality;
                    value: root.quality-status;
                    progress: root.quality-progress;
                    show-progress: true;
                    surface-color: root.surface-color;
                    border-color-token: root.border-color-token;
                    muted-color: root.text-muted-color;
                    value-color: root.text-primary-color;
                }

                MetricCard {
                    label: root.t-common-confidence;
                    value: root.profile-confidence;
                    progress: root.profile-confidence-progress;
                    show-progress: true;
                    surface-color: root.surface-color;
                    border-color-token: root.border-color-token;
                    muted-color: root.text-muted-color;
                    value-color: root.text-primary-color;
                }
            }
        }

        GroupBox {
            title: root.t-convert-status;

            TextEdit {
                text <=> root.status-text;
                read-only: true;
                min-height: 104px;
                font-size: 12px;
            }
        }
    }
}
