# AI Git 提交工具配置

# === 本地 Ollama（优先使用）========================================
# 若本机已运行 Ollama 并 `ollama pull gemma4:e4b`，自动启用本地推理，
# 免云端 token、免代理、零成本。失败时自动回退到下方 DashScope。
# 默认指向 http://127.0.0.1:11434；可改为局域网地址如 http://192.168.x.x:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e4b
# 设为 0 可强制关闭 Ollama 优先（仅使用 DashScope/托底）
# MYGIT_PREFER_OLLAMA=0

# === 云端 DashScope（备选）==========================================
# 您的 API 密钥
DASHSCOPE_API_KEY=sk-REDACTED-DASHSCOPE

# API 基础 URL (通常不需要修改)
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可用模型列表:
# - deepseek-v3: DeepSeek V3 模型
# - qwen-vl-plus: 通义千问视觉增强版
# - deepseek-r1: DeepSeek R1 推理模型
# - deepseek-v3.2-exp: DeepSeek V3.2 实验版
DASHSCOPE_MODEL=deepseek-v3

MYGIT_HTTP_PROXY=http://127.0.0.1:7890

# GitHub 推送凭据：请写入 .env.local（已 gitignore，勿提交 PAT）
# GITHUB_TOKEN=ghp_你的Personal_Access_Token
