# AI Git 提交工具配置（参考模板）

# === 本地 Ollama（优先使用）========================================
# 若本机已运行 Ollama 并 `ollama pull gemma4:e4b`，自动启用本地推理，
# 免云端 token、免代理、零成本。失败时自动回退到下方云端。
# 默认指向 http://127.0.0.1:11434；可改为局域网地址如 http://192.168.x.x:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e4b
# 设为 0 可强制关闭 Ollama 优先（仅使用云端/托底）
# MYGIT_PREFER_OLLAMA=0

# === 云端 DeepSeek（OpenAI 兼容 /v1/chat/completions）============
# 推荐键名 DEEPSEEK_*；脚本兼容旧名 DASHSCOPE_*。
# 默认 base_url 即 https://api.deepseek.com/v1，不写也可工作。
DEEPSEEK_API_KEY=sk-你的DeepSeek密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# === AI 总开关 ====================================================
# 默认 mygit.py 会暂停 AI（MYGIT_NO_AI=1）。设 MYGIT_FORCE_AI=1 让 AI
# 摘要生效；不想用 AI 时设 MYGIT_NO_AI=1 / MYGIT_FAST_RULES=1。
MYGIT_FORCE_AI=1
# MYGIT_NO_AI=1
# MYGIT_FAST_RULES=1

# === 网络 =========================================================
# WSL 下推荐指向本机代理端口；可省略，未检测到端口时自动直连。
MYGIT_HTTP_PROXY=http://127.0.0.1:7890

# GitHub 推送凭据：请写入 .env.local（已 gitignore，勿提交 PAT）
# GITHUB_TOKEN=ghp_你的Personal_Access_Token
