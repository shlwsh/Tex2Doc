import { TabWidget, VerticalBox, HorizontalBox } from "std-widgets.slint";
import { PlanEntry, JobRow, ConversionMode } from "types.slint";
import { ConvertTab } from "pages/convert.slint";
import { SettingsTab } from "pages/settings.slint";
import { AccountTab } from "pages/account.slint";
import { BillingTab } from "pages/billing.slint";
import { HistoryTab } from "pages/history.slint";

export component MainWindow inherits Window {
    title: is-signed-in ? t-app-title-signed-out + " " + app-version + " - " + account-display-name : t-app-title-signed-out + " " + app-version;
    icon: @image-url("assets/app_icon.jpg");
    preferred-width: 1120px;
    preferred-height: 780px;
    background: color-window-bg;

    in-out property <string> project-path;
    in-out property <string> api-base-url;
    in-out property <string> login-email;
    in-out property <string> login-password;
    in-out property <string> account-status: "Not signed in.";
    in-out property <string> usage-status: "--";
    in-out property <bool> is-signed-in: false;
    in-out property <bool> is-account-busy: false;
    in-out property <bool> is-billing-busy: false;
    in-out property <string> account-display-name: "Guest";
    in-out property <string> account-tier: "free";
    in-out property <int> quota-remaining: 0;
    in-out property <int> quota-total: 0;
    in-out property <string> billing-plan-id: "pro";
    in-out property <string> billing-status: "--";
    in-out property <[PlanEntry]> plan-catalog;
    in-out property <int> current-plan-index: 0;
    in-out property <string> update-channel: "stable";
    in-out property <string> update-status: "--";
    in-out property <string> ui-locale: "en";
    in-out property <string> ui-theme: "default";
    in-out property <string> app-version: "";
    in-out property <string> detected-profile: "auto";
    in-out property <string> main-tex;
    in-out property <string> quality-level: "standard";
    in-out property <string> output-path;
    in-out property <string> status-text: "";
    in-out property <bool> is-converting: false;
    in-out property <float> conversion-progress: 0.0;
    in-out property <bool> use-cloud-engine: false;
    in-out property <string> compatibility-score: "--";
    in-out property <float> compatibility-progress: 0.0;
    in-out property <string> quality-status: "--";
    in-out property <float> quality-progress: 0.0;
    in-out property <string> profile-confidence: "--";
    in-out property <float> profile-confidence-progress: 0.0;
    in-out property <string> recent-jobs: "No recent jobs.";
    in-out property <[JobRow]> job-history;
    in-out property <int> selected-job-index: -1;
    in-out property <bool> settings-dirty: false;
    in-out property <string> settings-saved-at: "";
    in-out property <string> settings-panel-state: "idle";

    in-out property <color> color-window-bg: #f6f8fb;
    in-out property <color> color-surface: #ffffff;
    in-out property <color> color-surface-alt: #f1f5f9;
    in-out property <color> color-border: #d7dee8;
    in-out property <color> color-text-primary: #172033;
    in-out property <color> color-text-secondary: #42526b;
    in-out property <color> color-text-muted: #6b778c;
    in-out property <color> color-accent: #2563eb;
    in-out property <color> color-success: #0f8a5f;
    in-out property <color> color-warning: #b7791f;
    in-out property <color> color-danger: #c2413a;

    in-out property <string> t-tab-convert: "Convert";
    in-out property <string> t-tab-settings: "Settings";
    in-out property <string> t-tab-account: "Account";
    in-out property <string> t-tab-billing: "Billing";
    in-out property <string> t-tab-history: "History";
    in-out property <string> t-app-title-signed-out: "Tex2Doc Desktop";
    in-out property <string> t-common-account: "Account";
    in-out property <string> t-common-quota: "Quota";
    in-out property <string> t-common-compatibility: "Compatibility";
    in-out property <string> t-common-confidence: "Confidence";
    in-out property <string> t-convert-engine: "Engine";
    in-out property <string> t-convert-local: "Local";
    in-out property <string> t-convert-cloud: "Cloud";
    in-out property <string> t-convert-cloud-requires-sign-in: "Cloud engine requires sign-in.";
    in-out property <string> t-convert-project: "Project";
    in-out property <string> t-convert-project-placeholder: "TeX project path or project zip...";
    in-out property <string> t-convert-folder: "Folder";
    in-out property <string> t-convert-zip: "Zip";
    in-out property <string> t-convert-main-tex-placeholder: "Main TeX for cloud conversion (optional, e.g. main.tex)...";
    in-out property <string> t-convert-options: "Options";
    in-out property <string> t-convert-profile: "Profile";
    in-out property <string> t-convert-quality: "Quality";
    in-out property <string> t-convert-output: "Output";
    in-out property <string> t-convert-output-placeholder: "Output DOCX path...";
    in-out property <string> t-convert-save-as: "Save As";
    in-out property <string> t-convert-detect-profile: "Detect Profile";
    in-out property <string> t-convert-detecting-profile: "[...] Detecting profile for: ";
    in-out property <string> t-convert-convert: "Convert";
    in-out property <string> t-convert-cloud-convert: "Cloud Convert";
    in-out property <string> t-convert-converting: "Converting...";
    in-out property <string> t-convert-uploading: "Uploading...";
    in-out property <string> t-convert-reading-source: "[1/3] Reading TeX source...";
    in-out property <string> t-convert-open-output: "Open Output";
    in-out property <string> t-convert-open-report: "Open Report";
    in-out property <string> t-convert-cloud-reason-sign-in: "Sign in to use cloud engine.";
    in-out property <string> t-convert-cloud-reason-api: "Set API base URL in Settings.";
    in-out property <string> t-convert-cloud-reason-fields: "Fill project and output paths above.";
    in-out property <string> t-convert-report: "Report";
    in-out property <string> t-convert-detected: "detected";
    in-out property <string> t-convert-status: "Status";
    in-out property <string> t-convert-ready: "Ready. Enter a project path and click Convert.";
    in-out property <string> t-settings-service: "Service";
    in-out property <string> t-settings-api-base-url-placeholder: "API base URL";
    in-out property <string> t-settings-default-params: "Default Conversion Parameters";
    in-out property <string> t-settings-default-profile: "Default Profile";
    in-out property <string> t-settings-default-quality: "Default Quality";
    in-out property <string> t-settings-default-output-dir: "Default Output Directory";
    in-out property <string> t-settings-updates: "Updates";
    in-out property <string> t-settings-release-channel-placeholder: "Release channel";
    in-out property <string> t-settings-check-update: "Check Update";
    in-out property <string> t-settings-checking-update: "Checking for updates...";
    in-out property <string> t-settings-appearance: "Appearance";
    in-out property <string> t-settings-language: "Language";
    in-out property <string> t-settings-theme: "Theme";
    in-out property <string> t-settings-apply-appearance: "Apply Appearance";
    in-out property <string> t-theme-default: "Default";
    in-out property <string> t-theme-blue: "Blue";
    in-out property <string> t-theme-green: "Green";
    in-out property <string> t-theme-purple: "Purple";
    in-out property <string> t-theme-orange: "Orange";
    in-out property <string> t-theme-dark: "Dark";
    in-out property <string> t-settings-about: "About";
    in-out property <string> t-settings-product: "Product";
    in-out property <string> t-settings-version: "Version";
    in-out property <string> t-account-sign-in-register: "Sign In / Register";
    in-out property <string> t-account-email: "Email";
    in-out property <string> t-account-password: "Password";
    in-out property <string> t-account-login: "Login";
    in-out property <string> t-account-register: "Register";
    in-out property <string> t-account-refresh: "Refresh";
    in-out property <string> t-account-logout: "Logout";
    in-out property <string> t-account-account: "Account";
    in-out property <string> t-account-display-name: "Display Name";
    in-out property <string> t-account-plan: "Plan";
    in-out property <string> t-account-quota: "Quota";
    in-out property <string> t-account-refresh-usage: "Refresh Usage";
    in-out property <string> t-account-signing-in: "Signing in...";
    in-out property <string> t-account-registering: "Registering...";
    in-out property <string> t-account-refreshing: "Refreshing...";
    in-out property <string> t-account-refreshing-usage: "Refreshing usage...";
    in-out property <string> t-billing-subscribe-manage: "Subscribe / Manage";
    in-out property <string> t-billing-plan-id: "Plan ID";
    in-out property <string> t-billing-plans: "Plans";
    in-out property <string> t-billing-checkout: "Checkout";
    in-out property <string> t-billing-portal: "Billing Portal";
    in-out property <string> t-billing-loading-plans: "Loading plans...";
    in-out property <string> t-billing-creating-checkout: "Creating checkout session...";
    in-out property <string> t-billing-opening-portal: "Opening billing portal...";
    in-out property <string> t-history-recent-jobs: "Recent Jobs";
    in-out property <string> t-history-no-recent-jobs: "No recent jobs.";
    in-out property <string> t-history-open-output: "Open Output";
    in-out property <string> t-history-open-report: "Open Report";
    in-out property <string> t-history-export-diagnostics: "Export Diagnostics";
    in-out property <string> t-history-exporting-diagnostics: "Exporting diagnostics...";

    callback convert-clicked(string, string, string, string);
    callback cloud-convert-clicked(string, string, string, string, string, string);
    callback detect-profile-clicked(string);
    callback login-clicked(string, string, string);
    callback register-clicked(string, string, string);
    callback refresh-login-clicked(string);
    callback logout-clicked();
    callback refresh-usage-clicked(string);
    callback show-plans-clicked(string);
    callback checkout-clicked(string, string);
    callback billing-portal-clicked(string);
    callback change-plan-clicked(string);
    callback check-update-clicked(string, string);
    callback apply-appearance-clicked(string, string);
    callback choose-project-folder-clicked(string, string);
    callback choose-project-zip-clicked(string, string);
    callback choose-output-clicked(string);
    callback save-settings-clicked();
    callback open-output-clicked(string);
    callback open-report-clicked(string);
    callback remove-job-clicked(string);
    callback clear-jobs-clicked();
    callback export-diagnostics-clicked(string, string, string, string, string, string, string, string);

    VerticalBox {
        spacing: 0px;

        Rectangle {
            height: 72px;
            background: root.color-surface;
            border-color: root.color-border;

            HorizontalBox {
                padding: 14px;
                spacing: 12px;

                Image {
                    source: @image-url("assets/app_icon.jpg");
                    width: 44px;
                    height: 44px;
                    image-fit: cover;
                }

                VerticalBox {
                    spacing: 2px;
                    horizontal-stretch: 1;

                    Text {
                        text: root.t-app-title-signed-out;
                        font-size: 20px;
                        font-weight: 700;
                        color: root.color-text-primary;
                    }

                    Text {
                        text: root.app-version == "" ? "Commercial document conversion workspace" : "Version " + root.app-version;
                        font-size: 12px;
                        color: root.color-text-secondary;
                    }
                }

                Rectangle {
                    background: root.is-signed-in ? #ECFDF5 : #FEF2F2;
                    border-radius: 999px;
                    min-width: 154px;
                    height: 30px;

                    Text {
                        text: root.is-signed-in ? root.account-display-name + " | " + root.account-tier : "Guest";
                        color: root.is-signed-in ? root.color-success : root.color-danger;
                        font-size: 12px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        TabWidget {
            Tab {
                title: root.t-tab-convert;
                ConvertTab {
                    project-path <=> root.project-path;
                    api-base-url <=> root.api-base-url;
                    main-tex <=> root.main-tex;
                    detected-profile <=> root.detected-profile;
                    quality-level <=> root.quality-level;
                    output-path <=> root.output-path;
                    is-converting <=> root.is-converting;
                    conversion-progress <=> root.conversion-progress;
                    compatibility-score <=> root.compatibility-score;
                    compatibility-progress <=> root.compatibility-progress;
                    quality-status <=> root.quality-status;
                    quality-progress <=> root.quality-progress;
                    profile-confidence <=> root.profile-confidence;
                    profile-confidence-progress <=> root.profile-confidence-progress;
                    status-text <=> root.status-text;
                    is-signed-in <=> root.is-signed-in;
                    quota-remaining <=> root.quota-remaining;
                    conversion-mode: root.use-cloud-engine ? ConversionMode.cloud : ConversionMode.local;
                    use-cloud-engine <=> root.use-cloud-engine;

                    surface-color: root.color-surface;
                    surface-alt-color: root.color-surface-alt;
                    border-color-token: root.color-border;
                    text-primary-color: root.color-text-primary;
                    text-secondary-color: root.color-text-secondary;
                    text-muted-color: root.color-text-muted;
                    accent-color: root.color-accent;
                    success-color: root.color-success;
                    warning-color: root.color-warning;
                    danger-color: root.color-danger;

                    t-convert-engine: root.t-convert-engine;
                    t-convert-local: root.t-convert-local;
                    t-convert-cloud: root.t-convert-cloud;
                    t-convert-cloud-requires-sign-in: root.t-convert-cloud-requires-sign-in;
                    t-convert-project: root.t-convert-project;
                    t-convert-project-placeholder: root.t-convert-project-placeholder;
                    t-convert-folder: root.t-convert-folder;
                    t-convert-zip: root.t-convert-zip;
                    t-convert-main-tex-placeholder: root.t-convert-main-tex-placeholder;
                    t-convert-options: root.t-convert-options;
                    t-convert-profile: root.t-convert-profile;
                    t-convert-quality: root.t-convert-quality;
                    t-convert-output: root.t-convert-output;
                    t-convert-output-placeholder: root.t-convert-output-placeholder;
                    t-convert-save-as: root.t-convert-save-as;
                    t-convert-detect-profile: root.t-convert-detect-profile;
                    t-convert-detecting-profile: root.t-convert-detecting-profile;
                    t-convert-convert: root.t-convert-convert;
                    t-convert-cloud-convert: root.t-convert-cloud-convert;
                    t-convert-converting: root.t-convert-converting;
                    t-convert-uploading: root.t-convert-uploading;
                    t-convert-reading-source: root.t-convert-reading-source;
                    t-convert-open-output: root.t-convert-open-output;
                    t-convert-open-report: root.t-convert-open-report;
                    t-convert-cloud-reason-sign-in: root.t-convert-cloud-reason-sign-in;
                    t-convert-cloud-reason-api: root.t-convert-cloud-reason-api;
                    t-convert-cloud-reason-fields: root.t-convert-cloud-reason-fields;
                    t-convert-report: root.t-convert-report;
                    t-convert-detected: root.t-convert-detected;
                    t-convert-status: root.t-convert-status;
                    t-convert-ready: root.t-convert-ready;
                    t-common-compatibility: root.t-common-compatibility;
                    t-common-confidence: root.t-common-confidence;
                    t-common-account: root.t-common-account;
                    t-common-quota: root.t-common-quota;

                    choose-project-folder-clicked(path, output) => { root.choose-project-folder-clicked(path, output); }
                    choose-project-zip-clicked(path, output) => { root.choose-project-zip-clicked(path, output); }
                    choose-output-clicked(path) => { root.choose-output-clicked(path); }
                    detect-profile-clicked(path) => { root.detect-profile-clicked(path); }
                    convert-clicked(project, profile, quality, output) => { root.convert-clicked(project, profile, quality, output); }
                    cloud-convert-clicked(api, project, main, profile, quality, output) => { root.cloud-convert-clicked(api, project, main, profile, quality, output); }
                    open-output-clicked(path) => { root.open-output-clicked(path); }
                    open-report-clicked(path) => { root.open-report-clicked(path); }
                }
            }

            Tab {
                title: root.t-tab-settings;
                SettingsTab {
                    detected-profile <=> root.detected-profile;
                    quality-level <=> root.quality-level;
                    output-path <=> root.output-path;
                    update-channel <=> root.update-channel;
                    update-status <=> root.update-status;
                    api-base-url <=> root.api-base-url;
                    ui-locale <=> root.ui-locale;
                    ui-theme <=> root.ui-theme;
                    is-converting <=> root.is-converting;
                    settings-dirty <=> root.settings-dirty;
                    settings-saved-at <=> root.settings-saved-at;
                    settings-panel-state <=> root.settings-panel-state;
                    app-version <=> root.app-version;

                    surface-alt-color: root.color-surface-alt;
                    border-color-token: root.color-border;
                    text-primary-color: root.color-text-primary;
                    text-secondary-color: root.color-text-secondary;
                    text-muted-color: root.color-text-muted;
                    success-color: root.color-success;
                    warning-color: root.color-warning;

                    t-settings-service: root.t-settings-service;
                    t-settings-api-base-url-placeholder: root.t-settings-api-base-url-placeholder;
                    t-settings-default-params: root.t-settings-default-params;
                    t-settings-default-profile: root.t-settings-default-profile;
                    t-settings-default-quality: root.t-settings-default-quality;
                    t-settings-default-output-dir: root.t-settings-default-output-dir;
                    t-settings-updates: root.t-settings-updates;
                    t-settings-release-channel-placeholder: root.t-settings-release-channel-placeholder;
                    t-settings-check-update: root.t-settings-check-update;
                    t-settings-checking-update: root.t-settings-checking-update;
                    t-settings-appearance: root.t-settings-appearance;
                    t-settings-language: root.t-settings-language;
                    t-settings-theme: root.t-settings-theme;
                    t-settings-apply-appearance: root.t-settings-apply-appearance;
                    t-settings-about: root.t-settings-about;
                    t-settings-product: root.t-settings-product;
                    t-settings-version: root.t-settings-version;
                    t-convert-output-placeholder: root.t-convert-output-placeholder;
                    t-convert-save-as: root.t-convert-save-as;

                    choose-output-clicked(path) => { root.choose-output-clicked(path); }
                    check-update-clicked(api, channel) => { root.check-update-clicked(api, channel); }
                    apply-appearance-clicked(locale, theme) => { root.apply-appearance-clicked(locale, theme); }
                    save-settings-clicked => { root.save-settings-clicked(); }
                }
            }

            Tab {
                title: root.t-tab-account;
                AccountTab {
                    api-base-url <=> root.api-base-url;
                    login-email <=> root.login-email;
                    login-password <=> root.login-password;
                    account-status <=> root.account-status;
                    usage-status <=> root.usage-status;
                    is-signed-in <=> root.is-signed-in;
                    is-account-busy <=> root.is-account-busy;
                    account-display-name <=> root.account-display-name;
                    quota-remaining <=> root.quota-remaining;
                    quota-total <=> root.quota-total;
                    account-tier <=> root.account-tier;

                    surface-color: root.color-surface;
                    surface-alt-color: root.color-surface-alt;
                    border-color-token: root.color-border;
                    text-primary-color: root.color-text-primary;
                    text-secondary-color: root.color-text-secondary;
                    text-muted-color: root.color-text-muted;
                    accent-color: root.color-accent;
                    success-color: root.color-success;
                    warning-color: root.color-warning;
                    danger-color: root.color-danger;

                    t-account-sign-in-register: root.t-account-sign-in-register;
                    t-account-email: root.t-account-email;
                    t-account-password: root.t-account-password;
                    t-account-login: root.t-account-login;
                    t-account-register: root.t-account-register;
                    t-account-refresh: root.t-account-refresh;
                    t-account-logout: root.t-account-logout;
                    t-account-account: root.t-account-account;
                    t-account-display-name: root.t-account-display-name;
                    t-account-plan: root.t-account-plan;
                    t-account-quota: root.t-account-quota;
                    t-account-refresh-usage: root.t-account-refresh-usage;
                    t-account-signing-in: root.t-account-signing-in;
                    t-account-registering: root.t-account-registering;
                    t-account-refreshing: root.t-account-refreshing;
                    t-account-refreshing-usage: root.t-account-refreshing-usage;

                    login-clicked(api, email, password) => { root.login-clicked(api, email, password); }
                    register-clicked(api, email, password) => { root.register-clicked(api, email, password); }
                    refresh-login-clicked(api) => { root.refresh-login-clicked(api); }
                    logout-clicked => { root.logout-clicked(); }
                    refresh-usage-clicked(api) => { root.refresh-usage-clicked(api); }
                }
            }

            Tab {
                title: root.t-tab-billing;
                BillingTab {
                    api-base-url <=> root.api-base-url;
                    billing-plan-id <=> root.billing-plan-id;
                    billing-status <=> root.billing-status;
                    plan-catalog <=> root.plan-catalog;
                    current-plan-index <=> root.current-plan-index;
                    is-billing-busy <=> root.is-billing-busy;
                    is-signed-in <=> root.is-signed-in;
                    account-tier <=> root.account-tier;
                    quota-remaining <=> root.quota-remaining;
                    quota-total <=> root.quota-total;

                    surface-color: root.color-surface;
                    surface-alt-color: root.color-surface-alt;
                    border-color-token: root.color-border;
                    text-primary-color: root.color-text-primary;
                    text-secondary-color: root.color-text-secondary;
                    text-muted-color: root.color-text-muted;
                    accent-color: root.color-accent;
                    success-color: root.color-success;
                    warning-color: root.color-warning;
                    danger-color: root.color-danger;

                    t-billing-subscribe-manage: root.t-billing-subscribe-manage;
                    t-billing-plan-id: root.t-billing-plan-id;
                    t-billing-plans: root.t-billing-plans;
                    t-billing-checkout: root.t-billing-checkout;
                    t-billing-portal: root.t-billing-portal;
                    t-billing-loading-plans: root.t-billing-loading-plans;
                    t-billing-creating-checkout: root.t-billing-creating-checkout;
                    t-billing-opening-portal: root.t-billing-opening-portal;

                    show-plans-clicked(api) => { root.show-plans-clicked(api); }
                    checkout-clicked(api, plan) => { root.checkout-clicked(api, plan); }
                    billing-portal-clicked(api) => { root.billing-portal-clicked(api); }
                    change-plan-clicked(plan) => {
                        root.billing-plan-id = plan;
                        root.change-plan-clicked(plan);
                    }
                }
            }

            Tab {
                title: root.t-tab-history;
                HistoryTab {
                    recent-jobs <=> root.recent-jobs;
                    project-path <=> root.project-path;
                    output-path <=> root.output-path;
                    api-base-url <=> root.api-base-url;
                    detected-profile <=> root.detected-profile;
                    quality-level <=> root.quality-level;
                    status-text <=> root.status-text;
                    update-status <=> root.update-status;
                    is-converting <=> root.is-converting;
                    job-history <=> root.job-history;
                    selected-job-index <=> root.selected-job-index;

                    surface-color: root.color-surface;
                    surface-alt-color: root.color-surface-alt;
                    border-color-token: root.color-border;
                    text-primary-color: root.color-text-primary;
                    text-secondary-color: root.color-text-secondary;
                    text-muted-color: root.color-text-muted;
                    accent-color: root.color-accent;
                    success-color: root.color-success;
                    danger-color: root.color-danger;

                    t-history-recent-jobs: root.t-history-recent-jobs;
                    t-history-no-recent-jobs: root.t-history-no-recent-jobs;
                    t-history-open-output: root.t-history-open-output;
                    t-history-open-report: root.t-history-open-report;
                    t-history-export-diagnostics: root.t-history-export-diagnostics;
                    t-history-exporting-diagnostics: root.t-history-exporting-diagnostics;

                    export-diagnostics-clicked(project, output, api, profile, quality, status, recent, update) => {
                        root.export-diagnostics-clicked(project, output, api, profile, quality, status, recent, update);
                    }
                    remove-job-clicked(id) => { root.remove-job-clicked(id); }
                    clear-jobs-clicked => { root.clear-jobs-clicked(); }
                    open-output-clicked(path) => { root.open-output-clicked(path); }
                    open-report-clicked(path) => { root.open-report-clicked(path); }
                }
            }
        }
    }
}
