import { TabWidget, Button, VerticalBox, HorizontalBox, LineEdit, TextEdit, ComboBox, ProgressIndicator, GroupBox } from "std-widgets.slint";

export component MainWindow inherits Window {
    title: "Tex2Doc Desktop";
    preferred-width: 1080px;
    preferred-height: 760px;

    // ?? State properties ??????????????????????????????????????????????????????
    in-out property <string> project-path;
    in-out property <string> api-base-url;
    in-out property <string> login-email;
    in-out property <string> login-password;
    in-out property <string> account-status: "Not signed in.";
    in-out property <string> usage-status: "--";
    in-out property <string> billing-plan-id: "pro";
    in-out property <string> billing-status: "--";
    in-out property <string> update-channel: "stable";
    in-out property <string> update-status: "--";
    in-out property <string> detected-profile: "auto";
    in-out property <string> main-tex;
    in-out property <string> quality-level: "standard";
    in-out property <string> output-path;
    in-out property <string> status-text: "Ready. Enter a project path and click Convert.";
    in-out property <bool> is-converting: false;
    in-out property <float> conversion-progress: 0.0;
    in-out property <string> compatibility-score: "--";
    in-out property <string> quality-status: "--";
    in-out property <string> profile-confidence: "--";
    in-out property <string> recent-jobs: "No recent jobs.";

    // ?? Callbacks (implemented in Rust) ?????????????????????????????????????
    callback convert-clicked(string, string, string, string);
    callback cloud-convert-clicked(string, string, string, string, string, string);
    callback detect-profile-clicked(string);
    callback login-clicked(string, string, string);
    callback register-clicked(string, string, string);
    callback refresh-login-clicked(string);
    callback logout-clicked();
    callback refresh-usage-clicked(string);
    callback show-plans-clicked(string);
    callback checkout-clicked(string, string);
    callback billing-portal-clicked(string);
    callback check-update-clicked(string, string);
    callback choose-project-folder-clicked(string, string);
    callback choose-project-zip-clicked(string, string);
    callback choose-output-clicked(string);
    callback open-output-clicked(string);
    callback open-report-clicked(string);
    callback export-diagnostics-clicked(string, string, string, string, string, string, string, string);

    TabWidget {

        // ?? Tab 1: Convert ???????????????????????????????????????????????
        Tab {
            title: "Convert";
            VerticalBox {
                padding: 16px;
                spacing: 10px;

                GroupBox {
                    title: "Project";

                    VerticalBox {
                        spacing: 6px;

                        HorizontalBox {
                            spacing: 8px;

                            LineEdit {
                                placeholder-text: "TeX project path or project zip...";
                                text <=> project-path;
                            }

                            Button {
                                text: "Folder";
                                enabled: !is-converting;
                                clicked => {
                                    root.choose-project-folder-clicked(root.project-path, root.output-path);
                                }
                            }

                            Button {
                                text: "Zip";
                                enabled: !is-converting;
                                clicked => {
                                    root.choose-project-zip-clicked(root.project-path, root.output-path);
                                }
                            }
                        }

                        LineEdit {
                            placeholder-text: "Main TeX for cloud conversion (optional, e.g. main-jos.tex)...";
                            text <=> main-tex;
                        }
                    }
                }

                GroupBox {
                    title: "Options";

                    HorizontalBox {
                        spacing: 16px;

                        VerticalBox {
                            Text { text: "Profile"; font-size: 12px; }
                            ComboBox {
                                current-value: detected-profile;
                                model: ["auto", "generic-article", "tacl", "cvpr", "nature", "springer", "jos-paper", "chinese-academic"];
                            }
                        }

                        VerticalBox {
                            Text { text: "Quality"; font-size: 12px; }
                            ComboBox {
                                current-value: quality-level;
                                model: ["preview", "standard", "strict"];
                            }
                        }

                        VerticalBox {
                            Text { text: "Output"; font-size: 12px; }
                            HorizontalBox {
                                spacing: 6px;
                                LineEdit {
                                    placeholder-text: "Output DOCX path...";
                                    text <=> output-path;
                                }
                                Button {
                                    text: "Save As";
                                    enabled: !is-converting;
                                    clicked => { root.choose-output-clicked(root.output-path); }
                                }
                            }
                        }
                    }
                }

                HorizontalBox {
                    spacing: 8px;

                    Button {
                        text: "Detect Profile";
                        enabled: project-path != "" && !is-converting;
                        clicked => {
                            root.status-text = "[...] Detecting profile for: " + project-path + "...";
                            root.detect-profile-clicked(root.project-path);
                        }
                    }

                    Button {
                        text: "Local Convert";
                        enabled: project-path != "" && output-path != "" && !is-converting;
                        clicked => {
                            root.is-converting = true;
                            root.status-text = "[1/3] Reading TeX source...";
                            root.conversion-progress = 0.1;
                            root.convert-clicked(root.project-path, root.detected-profile, root.quality-level, root.output-path);
                        }
                    }

                    Button {
                        text: "Cloud Convert";
                        enabled: api-base-url != "" && project-path != "" && output-path != "" && !is-converting;
                        clicked => {
                            root.is-converting = true;
                            root.status-text = "[cloud] Uploading TeX project...";
                            root.conversion-progress = 0.1;
                            root.cloud-convert-clicked(root.api-base-url, root.project-path, root.main-tex, root.detected-profile, root.quality-level, root.output-path);
                        }
                    }

                    Button {
                        text: "Open Output";
                        enabled: !is-converting && output-path != "";
                        clicked => { root.open-output-clicked(root.output-path); }
                    }

                    Button {
                        text: "Open Report";
                        enabled: !is-converting && output-path != "";
                        clicked => { root.open-report-clicked(root.output-path); }
                    }
                }

                ProgressIndicator {
                    progress: conversion-progress;
                    visible: is-converting;
                }

                GroupBox {
                    title: "Report";

                    HorizontalBox {
                        spacing: 16px;

                        VerticalBox {
                            Text { text: "Profile"; font-size: 11px; color: #666; }
                            Text { text: detected-profile; font-size: 14px; font-weight: 600; }
                        }

                        VerticalBox {
                            Text { text: "Compatibility"; font-size: 11px; color: #666; }
                            Text { text: compatibility-score + "%"; font-size: 14px; font-weight: 600; }
                        }

                        VerticalBox {
                            Text { text: "Quality"; font-size: 11px; color: #666; }
                            Text { text: quality-status; font-size: 14px; font-weight: 600; }
                        }

                        VerticalBox {
                            Text { text: "Confidence"; font-size: 11px; color: #666; }
                            Text { text: profile-confidence; font-size: 14px; font-weight: 600; }
                        }
                    }
                }

                GroupBox {
                    title: "Status";

                    TextEdit {
                        text <=> status-text;
                        read-only: true;
                        min-height: 100px;
                        font-size: 12px;
                    }
                }
            }
        }

        // ?? Tab 2: Settings ???????????????????????????????????????????????
        Tab {
            title: "Settings";
            VerticalBox {
                padding: 16px;
                spacing: 10px;

                GroupBox {
                    title: "Service";

                    VerticalBox {
                        spacing: 6px;

                        LineEdit {
                            placeholder-text: "API base URL";
                            text <=> api-base-url;
                        }
                    }
                }

                GroupBox {
                    title: "Default Conversion Parameters";

                    VerticalBox {
                        spacing: 6px;

                        HorizontalBox {
                            spacing: 16px;

                            VerticalBox {
                                Text { text: "Default Profile"; font-size: 12px; }
                                ComboBox {
                                    current-value: detected-profile;
                                    model: ["auto", "generic-article", "tacl", "cvpr", "nature", "springer", "jos-paper", "chinese-academic"];
                                }
                            }

                            VerticalBox {
                                Text { text: "Default Quality"; font-size: 12px; }
                                ComboBox {
                                    current-value: quality-level;
                                    model: ["preview", "standard", "strict"];
                                }
                            }
                        }

                        HorizontalBox {
                            spacing: 8px;
                            VerticalBox {
                                Text { text: "Default Output Directory"; font-size: 12px; }
                            }
                        }

                        HorizontalBox {
                            spacing: 8px;
                            LineEdit {
                                placeholder-text: "Default output DOCX path...";
                                text <=> output-path;
                            }
                            Button {
                                text: "Save As";
                                enabled: !is-converting;
                                clicked => { root.choose-output-clicked(root.output-path); }
                            }
                        }
                    }
                }

                GroupBox {
                    title: "Updates";

                    VerticalBox {
                        spacing: 6px;

                        HorizontalBox {
                            spacing: 8px;

                            LineEdit {
                                placeholder-text: "Release channel";
                                text <=> update-channel;
                            }

                            Button {
                                text: "Check Update";
                                enabled: api-base-url != "";
                                clicked => {
                                    root.update-status = "Checking for updates...";
                                    root.check-update-clicked(root.api-base-url, root.update-channel);
                                }
                            }
                        }

                        Text { text: update-status; font-size: 12px; }
                    }
                }
            }
        }

        // ?? Tab 3: Account ???????????????????????????????????????????????
        Tab {
            title: "Account";
            VerticalBox {
                padding: 16px;
                spacing: 10px;

                GroupBox {
                    title: "Sign In / Register";

                    VerticalBox {
                        spacing: 6px;

                        HorizontalBox {
                            spacing: 8px;

                            LineEdit {
                                placeholder-text: "Email";
                                text <=> login-email;
                            }

                            LineEdit {
                                placeholder-text: "Password";
                                text <=> login-password;
                            }
                        }

                        HorizontalBox {
                            spacing: 8px;

                            Button {
                                text: "Login";
                                enabled: api-base-url != "" && login-email != "";
                                clicked => {
                                    root.account-status = "Signing in...";
                                    root.login-clicked(root.api-base-url, root.login-email, root.login-password);
                                }
                            }

                            Button {
                                text: "Register";
                                enabled: api-base-url != "" && login-email != "";
                                clicked => {
                                    root.account-status = "Registering...";
                                    root.register-clicked(root.api-base-url, root.login-email, root.login-password);
                                }
                            }

                            Button {
                                text: "Refresh";
                                enabled: api-base-url != "";
                                clicked => {
                                    root.account-status = "Refreshing login...";
                                    root.refresh-login-clicked(root.api-base-url);
                                }
                            }

                            Button {
                                text: "Logout";
                                clicked => { root.logout-clicked(); }
                            }
                        }
                    }
                }

                GroupBox {
                    title: "Session";

                    VerticalBox {
                        spacing: 6px;

                        Button {
                            text: "Refresh Usage";
                            enabled: api-base-url != "";
                            clicked => {
                                root.usage-status = "Refreshing usage...";
                                root.refresh-usage-clicked(root.api-base-url);
                            }
                        }

                        Text { text: account-status; font-size: 12px; }
                        Text { text: usage-status; font-size: 12px; }
                    }
                }
            }
        }

        // ?? Tab 4: Plans ?????????????????????????????????????????????????
        Tab {
            title: "Plans";
            VerticalBox {
                padding: 16px;
                spacing: 10px;

                GroupBox {
                    title: "Subscription";

                    VerticalBox {
                        spacing: 6px;

                        HorizontalBox {
                            spacing: 8px;

                            LineEdit {
                                placeholder-text: "Plan ID";
                                text <=> billing-plan-id;
                            }

                            Button {
                                text: "Plans";
                                enabled: api-base-url != "";
                                clicked => {
                                    root.billing-status = "Loading plans...";
                                    root.show-plans-clicked(root.api-base-url);
                                }
                            }
                        }

                        HorizontalBox {
                            spacing: 8px;

                            Button {
                                text: "Checkout";
                                enabled: api-base-url != "" && billing-plan-id != "";
                                clicked => {
                                    root.billing-status = "Creating checkout session...";
                                    root.checkout-clicked(root.api-base-url, root.billing-plan-id);
                                }
                            }

                            Button {
                                text: "Billing Portal";
                                enabled: api-base-url != "";
                                clicked => {
                                    root.billing-status = "Opening billing portal...";
                                    root.billing-portal-clicked(root.api-base-url);
                                }
                            }
                        }

                        Text { text: billing-status; font-size: 12px; }
                    }
                }
            }
        }

        // ?? Tab 5: History ???????????????????????????????????????????????
        Tab {
            title: "History";
            VerticalBox {
                padding: 16px;
                spacing: 10px;

                GroupBox {
                    title: "Recent Jobs";

                    VerticalBox {
                        spacing: 6px;

                        TextEdit {
                            text <=> recent-jobs;
                            read-only: true;
                            min-height: 180px;
                            font-size: 11px;
                        }

                        HorizontalBox {
                            spacing: 8px;

                            Button {
                                text: "Open Output";
                                enabled: output-path != "";
                                clicked => { root.open-output-clicked(root.output-path); }
                            }

                            Button {
                                text: "Open Report";
                                enabled: output-path != "";
                                clicked => { root.open-report-clicked(root.output-path); }
                            }

                            Button {
                                text: "Export Diagnostics";
                                enabled: !is-converting;
                                clicked => {
                                    root.export-diagnostics-clicked(root.project-path, root.output-path, root.api-base-url, root.detected-profile, root.quality-level, root.status-text, root.recent-jobs, root.update-status);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
