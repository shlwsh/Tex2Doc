import {
    Button,
    VerticalBox,
    HorizontalBox,
    LineEdit,
    TextEdit,
    ComboBox,
    ProgressIndicator,
    ListView,
    Switch,
} from "std-widgets.slint";
import { PlanEntry, JobRow, ConversionMode } from "types.slint";

component NavButton inherits Rectangle {
    in property <string> label;
    in property <string> detail;
    in property <bool> selected: false;
    in property <color> accent: #2563eb;
    in property <color> text-primary: #172033;
    in property <color> text-muted: #6b778c;
    callback clicked();

    height: 54px;
    border-radius: 8px;
    background: selected ? #eff6ff : #00000000;

    TouchArea { clicked => { root.clicked(); } }

    HorizontalBox {
        padding-left: 14px;
        padding-right: 12px;
        spacing: 10px;

        Rectangle {
            width: 4px;
            height: 28px;
            border-radius: 2px;
            background: root.selected ? root.accent : #00000000;
        }

        VerticalBox {
            vertical-stretch: 1;
            spacing: 2px;
            Text {
                text: root.label;
                font-size: 14px;
                font-weight: root.selected ? 700 : 500;
                color: root.selected ? root.accent : root.text-primary;
                vertical-alignment: bottom;
            }
            Text {
                text: root.detail;
                font-size: 11px;
                color: root.text-muted;
                overflow: elide;
                vertical-alignment: top;
            }
        }
    }
}

component MetricTile inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> note;
    in property <color> surface: #ffffff;
    in property <color> border: #d7dee8;
    in property <color> text-primary: #172033;
    in property <color> text-muted: #6b778c;
    in property <color> accent: #2563eb;

    min-height: 86px;
    border-radius: 8px;
    border-color: border;
    background: surface;

    VerticalBox {
        padding: 14px;
        spacing: 5px;
        Text { text: root.label; font-size: 11px; color: root.text-muted; }
        Text { text: root.value; font-size: 22px; font-weight: 700; color: root.text-primary; overflow: elide; }
        Text { text: root.note; font-size: 11px; color: root.accent; overflow: elide; }
    }
}

component SectionPanel inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <color> surface: #ffffff;
    in property <color> border: #d7dee8;
    in property <color> text-primary: #172033;
    in property <color> text-muted: #6b778c;

    border-radius: 8px;
    border-color: border;
    background: surface;

    VerticalBox {
        padding: 18px;
        spacing: 4px;
        Text { text: root.title; font-size: 18px; font-weight: 700; color: root.text-primary; }
        Text { text: root.subtitle; font-size: 12px; color: root.text-muted; wrap: word-wrap; }
    }
}

component StatusPill inherits Rectangle {
    in property <string> text;
    in property <color> bg: #eff6ff;
    in property <color> fg: #2563eb;

    height: 26px;
    min-width: 86px;
    border-radius: 999px;
    background: bg;

    Text {
        text: root.text;
        color: root.fg;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component MainWindow inherits Window {
    title: t-app-title-signed-out + " " + app-version;
    icon: @image-url("assets/app_icon.jpg");
    preferred-width: 1220px;
    preferred-height: 790px;
    background: color-window-bg;

    in-out property <int> selected-page: 2;
    in-out property <bool> account-menu-open: false;
    in-out property <bool> profile-dialog-open: false;
    in-out property <bool> password-dialog-open: false;
    in-out property <string> password-old;
    in-out property <string> password-new;
    in-out property <string> password-confirm;
    in-out property <bool> toast-visible: false;
    in-out property <string> toast-message: "";
    in-out property <string> toast-level: "info";

    in-out property <string> project-path;
    in-out property <string> api-base-url;
    in-out property <string> login-email;
    in-out property <string> login-password;
    in-out property <string> account-status: "Not signed in.";
    in-out property <string> usage-status: "--";
    in-out property <bool> is-signed-in: false;
    in-out property <bool> is-account-busy: false;
    in-out property <bool> is-billing-busy: false;
    in-out property <string> account-display-name: "Guest";
    in-out property <string> account-tier: "free";
    in-out property <int> quota-remaining: 0;
    in-out property <int> quota-total: 0;
    in-out property <string> billing-plan-id: "pro";
    in-out property <string> billing-status: "--";
    in-out property <[PlanEntry]> plan-catalog;
    in-out property <int> current-plan-index: 0;
    in-out property <string> update-channel: "stable";
    in-out property <string> update-status: "--";
    in-out property <string> ui-locale: "en";
    in-out property <string> ui-theme: "default";
    in-out property <string> app-version: "";
    in-out property <string> detected-profile: "auto";
    in-out property <string> main-tex;
    in-out property <string> quality-level: "standard";
    in-out property <string> output-path;
    in-out property <string> status-text: "";
    in-out property <bool> is-converting: false;
    in-out property <float> conversion-progress: 0.0;
    in-out property <bool> use-cloud-engine: true;
    in-out property <string> compatibility-score: "--";
    in-out property <float> compatibility-progress: 0.0;
    in-out property <string> quality-status: "--";
    in-out property <float> quality-progress: 0.0;
    in-out property <string> profile-confidence: "--";
    in-out property <float> profile-confidence-progress: 0.0;
    in-out property <string> recent-jobs: "No recent jobs.";
    in-out property <[JobRow]> job-history;
    in-out property <int> selected-job-index: -1;
    in-out property <bool> settings-dirty: false;
    in-out property <string> settings-saved-at: "";
    in-out property <string> settings-panel-state: "idle";

    in-out property <color> color-window-bg: #f6f8fb;
    in-out property <color> color-surface: #ffffff;
    in-out property <color> color-surface-alt: #f1f5f9;
    in-out property <color> color-border: #d7dee8;
    in-out property <color> color-text-primary: #172033;
    in-out property <color> color-text-secondary: #42526b;
    in-out property <color> color-text-muted: #6b778c;
    in-out property <color> color-accent: #2563eb;
    in-out property <color> color-success: #0f8a5f;
    in-out property <color> color-warning: #b7791f;
    in-out property <color> color-danger: #c2413a;

    in-out property <string> t-tab-convert: "Convert";
    in-out property <string> t-tab-settings: "Settings";
    in-out property <string> t-tab-account: "Account";
    in-out property <string> t-tab-billing: "Billing";
    in-out property <string> t-tab-history: "History";
    in-out property <string> t-app-title-signed-out: "Tex2Doc Desktop";
    in-out property <string> t-common-account: "Account";
    in-out property <string> t-common-quota: "Quota";
    in-out property <string> t-common-compatibility: "Compatibility";
    in-out property <string> t-common-confidence: "Confidence";
    in-out property <string> t-convert-engine: "Engine";
    in-out property <string> t-convert-local: "Local";
    in-out property <string> t-convert-cloud: "Cloud";
    in-out property <string> t-convert-cloud-requires-sign-in: "Cloud engine requires sign-in.";
    in-out property <string> t-convert-project: "Project";
    in-out property <string> t-convert-project-placeholder: "TeX project path or project zip...";
    in-out property <string> t-convert-folder: "Folder";
    in-out property <string> t-convert-zip: "Zip";
    in-out property <string> t-convert-main-tex-placeholder: "Main TeX for cloud conversion (optional, e.g. main.tex)...";
    in-out property <string> t-convert-options: "Options";
    in-out property <string> t-convert-profile: "Profile";
    in-out property <string> t-convert-quality: "Quality";
    in-out property <string> t-convert-output: "Output";
    in-out property <string> t-convert-output-placeholder: "Output DOCX path...";
    in-out property <string> t-convert-save-as: "Save As";
    in-out property <string> t-convert-detect-profile: "Detect Profile";
    in-out property <string> t-convert-detecting-profile: "[...] Detecting profile for: ";
    in-out property <string> t-convert-convert: "Convert";
    in-out property <string> t-convert-cloud-convert: "Cloud Convert";
    in-out property <string> t-convert-converting: "Converting...";
    in-out property <string> t-convert-uploading: "Uploading...";
    in-out property <string> t-convert-reading-source: "[1/3] Reading TeX source...";
    in-out property <string> t-convert-open-output: "Open Output";
    in-out property <string> t-convert-open-report: "Open Report";
    in-out property <string> t-convert-cloud-reason-sign-in: "Sign in to use cloud engine.";
    in-out property <string> t-convert-cloud-reason-api: "Set API base URL in Settings.";
    in-out property <string> t-convert-cloud-reason-fields: "Fill project and output paths above.";
    in-out property <string> t-convert-report: "Report";
    in-out property <string> t-convert-detected: "detected";
    in-out property <string> t-convert-status: "Status";
    in-out property <string> t-convert-ready: "Ready. Enter a project path and click Convert.";
    in-out property <string> t-settings-service: "Service";
    in-out property <string> t-settings-api-base-url-placeholder: "API base URL";
    in-out property <string> t-settings-default-params: "Default Conversion Parameters";
    in-out property <string> t-settings-default-profile: "Default Profile";
    in-out property <string> t-settings-default-quality: "Default Quality";
    in-out property <string> t-settings-default-output-dir: "Default Output Directory";
    in-out property <string> t-settings-updates: "Updates";
    in-out property <string> t-settings-release-channel-placeholder: "Release channel";
    in-out property <string> t-settings-check-update: "Check Update";
    in-out property <string> t-settings-checking-update: "Checking for updates...";
    in-out property <string> t-settings-appearance: "Appearance";
    in-out property <string> t-settings-language: "Language";
    in-out property <string> t-settings-theme: "Theme";
    in-out property <string> t-settings-apply-appearance: "Apply Appearance";
    in-out property <string> t-theme-default: "Default";
    in-out property <string> t-theme-blue: "Blue";
    in-out property <string> t-theme-green: "Green";
    in-out property <string> t-theme-purple: "Purple";
    in-out property <string> t-theme-orange: "Orange";
    in-out property <string> t-theme-dark: "Dark";
    in-out property <string> t-settings-about: "About";
    in-out property <string> t-settings-product: "Product";
    in-out property <string> t-settings-version: "Version";
    in-out property <string> t-account-sign-in-register: "Sign In / Register";
    in-out property <string> t-account-email: "Email";
    in-out property <string> t-account-password: "Password";
    in-out property <string> t-account-login: "Login";
    in-out property <string> t-account-register: "Register";
    in-out property <string> t-account-refresh: "Refresh";
    in-out property <string> t-account-logout: "Logout";
    in-out property <string> t-account-account: "Account";
    in-out property <string> t-account-display-name: "Display Name";
    in-out property <string> t-account-plan: "Plan";
    in-out property <string> t-account-quota: "Quota";
    in-out property <string> t-account-refresh-usage: "Refresh Usage";
    in-out property <string> t-account-signing-in: "Signing in...";
    in-out property <string> t-account-registering: "Registering...";
    in-out property <string> t-account-refreshing: "Refreshing...";
    in-out property <string> t-account-refreshing-usage: "Refreshing usage...";
    in-out property <string> t-billing-subscribe-manage: "Subscribe / Manage";
    in-out property <string> t-billing-plan-id: "Plan ID";
    in-out property <string> t-billing-plans: "Plans";
    in-out property <string> t-billing-checkout: "Checkout";
    in-out property <string> t-billing-portal: "Billing Portal";
    in-out property <string> t-billing-loading-plans: "Loading plans...";
    in-out property <string> t-billing-creating-checkout: "Creating checkout session...";
    in-out property <string> t-billing-opening-portal: "Opening billing portal...";
    in-out property <string> t-history-recent-jobs: "Recent Jobs";
    in-out property <string> t-history-no-recent-jobs: "No recent jobs.";
    in-out property <string> t-history-open-output: "Open Output";
    in-out property <string> t-history-open-report: "Open Report";
    in-out property <string> t-history-export-diagnostics: "Export Diagnostics";
    in-out property <string> t-history-exporting-diagnostics: "Exporting diagnostics...";

    callback convert-clicked(string, string, string, string);
    callback cloud-convert-clicked(string, string, string, string, string, string);
    callback detect-profile-clicked(string);
    callback login-clicked(string, string, string);
    callback register-clicked(string, string, string);
    callback refresh-login-clicked(string);
    callback logout-clicked();
    callback refresh-usage-clicked(string);
    callback show-plans-clicked(string);
    callback checkout-clicked(string, string);
    callback billing-portal-clicked(string);
    callback change-plan-clicked(string);
    callback check-update-clicked(string, string);
    callback apply-appearance-clicked(string, string);
    callback choose-project-folder-clicked(string, string);
    callback choose-project-zip-clicked(string, string);
    callback choose-output-clicked(string);
    callback save-settings-clicked();
    callback open-output-clicked(string);
    callback open-report-clicked(string);
    callback remove-job-clicked(string);
    callback clear-jobs-clicked();
    callback export-diagnostics-clicked(string, string, string, string, string, string, string, string);

    HorizontalBox {
        spacing: 0px;

        Rectangle {
            width: 248px;
            background: color-surface-alt;
            border-color: color-border;

            VerticalBox {
                padding: 18px;
                spacing: 16px;

                HorizontalBox {
                    spacing: 10px;
                    Image { source: @image-url("assets/app_icon.jpg"); width: 38px; height: 38px; image-fit: cover; }
                    VerticalBox {
                        spacing: 1px;
                        Text { text: "Tex2Doc"; font-size: 20px; font-weight: 700; color: color-text-primary; }
                        Text { text: "Commercial workspace"; font-size: 11px; color: color-text-muted; overflow: elide; }
                    }
                }

                NavButton { label: t-common-account; detail: is-signed-in ? account-tier : "Sign in first"; selected: selected-page == 0; accent: color-accent; text-primary: color-text-primary; text-muted: color-text-muted; clicked => { selected-page = 0; } }
                NavButton { label: "Recharge"; detail: "Quota and billing"; selected: selected-page == 1; accent: color-accent; text-primary: color-text-primary; text-muted: color-text-muted; clicked => { selected-page = 1; } }
                NavButton { label: t-tab-convert; detail: "Cloud semantic engine"; selected: selected-page == 2; accent: color-accent; text-primary: color-text-primary; text-muted: color-text-muted; clicked => { selected-page = 2; } }
                NavButton { label: "Conversion Records"; detail: "Jobs and reports"; selected: selected-page == 3; accent: color-accent; text-primary: color-text-primary; text-muted: color-text-muted; clicked => { selected-page = 3; } }
                NavButton { label: "Recharge Records"; detail: "Mock payment history"; selected: selected-page == 4; accent: color-accent; text-primary: color-text-primary; text-muted: color-text-muted; clicked => { selected-page = 4; } }

                Rectangle { vertical-stretch: 1; }

                SectionPanel {
                    title: is-signed-in ? account-display-name : "Guest";
                    subtitle: is-signed-in ? usage-status : account-status;
                    surface: color-surface;
                    border: color-border;
                    text-primary: color-text-primary;
                    text-muted: color-text-muted;
                }
            }
        }

        VerticalBox {
            spacing: 0px;

            Rectangle {
                height: 64px;
                background: color-surface;
                border-color: color-border;

                HorizontalBox {
                    padding-left: 22px;
                    padding-right: 22px;
                    spacing: 14px;

                    VerticalBox {
                        horizontal-stretch: 1;
                        spacing: 1px;
                        Text {
                            text: selected-page == 0 ? "Account Overview" : (selected-page == 1 ? "Recharge" : (selected-page == 2 ? "Document Conversion" : (selected-page == 3 ? "Conversion Records" : "Recharge Records")));
                            font-size: 20px;
                            font-weight: 700;
                            color: color-text-primary;
                            vertical-alignment: bottom;
                        }
                        Text {
                            text: app-version == "" ? "LaTeX to DOCX commercial workspace" : "Version " + app-version;
                            font-size: 11px;
                            color: color-text-muted;
                            vertical-alignment: top;
                        }
                    }

                    ComboBox {
                        width: 112px;
                        current-value <=> ui-locale;
                        model: ["en", "zh-Hans", "zh-Hant", "fr", "ja-JP", "de"];
                        selected(_) => { apply-appearance-clicked(ui-locale, ui-theme); }
                    }

                    ComboBox {
                        width: 112px;
                        current-value <=> ui-theme;
                        model: ["default", "blue", "green", "purple", "orange", "dark"];
                        selected(_) => { apply-appearance-clicked(ui-locale, ui-theme); }
                    }

                    Rectangle {
                        width: 38px;
                        height: 38px;
                        border-radius: 19px;
                        background: is-signed-in ? color-accent : color-border;

                        Text {
                            text: is-signed-in ? "T" : "?";
                            color: #ffffff;
                            font-size: 16px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea { clicked => { account-menu-open = !account-menu-open; } }
                    }
                }
            }

            Rectangle {
                background: color-window-bg;
                horizontal-stretch: 1;
                vertical-stretch: 1;

                if selected-page == 0: Rectangle {
                    background: color-window-bg;
                    VerticalBox {
                        padding: 22px;
                        spacing: 16px;

                        HorizontalBox {
                            spacing: 14px;
                            MetricTile { label: "Plan"; value: account-tier; note: is-signed-in ? "Active subscription" : "Guest mode"; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-accent; }
                            MetricTile { label: "Remaining"; value: "" + quota-remaining; note: t-common-quota; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-success; }
                            MetricTile { label: "Status"; value: is-signed-in ? "Signed in" : "Guest"; note: account-status; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-warning; }
                        }

                        SectionPanel { title: t-account-sign-in-register; subtitle: "Use the commercial API account to unlock cloud conversion, quota records, and billing operations."; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; }

                        Rectangle {
                            border-radius: 8px;
                            border-color: color-border;
                            background: color-surface;
                            VerticalBox {
                                padding: 18px;
                                spacing: 10px;
                                LineEdit { placeholder-text: t-settings-api-base-url-placeholder; text <=> api-base-url; }
                                LineEdit { placeholder-text: t-account-email; text <=> login-email; }
                                LineEdit { placeholder-text: t-account-password; text <=> login-password; }
                                HorizontalBox {
                                    spacing: 10px;
                                    Button { text: is-account-busy ? t-account-signing-in : t-account-login; primary: true; enabled: !is-account-busy && api-base-url != "" && login-email != ""; clicked => { is-account-busy = true; login-clicked(api-base-url, login-email, login-password); toast-message = "Signing in..."; toast-level = "info"; toast-visible = true; } }
                                    Button { text: is-account-busy ? t-account-registering : t-account-register; enabled: !is-account-busy && api-base-url != "" && login-email != ""; clicked => { is-account-busy = true; register-clicked(api-base-url, login-email, login-password); toast-message = "Registering..."; toast-level = "info"; toast-visible = true; } }
                                    Button { text: t-account-refresh; enabled: api-base-url != ""; clicked => { is-account-busy = true; refresh-login-clicked(api-base-url); } }
                                    Button { text: t-account-logout; enabled: is-signed-in; clicked => { logout-clicked(); toast-message = "Signed out."; toast-level = "info"; toast-visible = true; } }
                                    Button { text: t-account-refresh-usage; enabled: is-signed-in && api-base-url != ""; clicked => { refresh-usage-clicked(api-base-url); } }
                                }
                                Text { text: account-status + "\n" + usage-status; font-size: 12px; color: color-text-secondary; wrap: word-wrap; }
                            }
                        }
                    }
                }

                if selected-page == 1: Rectangle {
                    background: color-window-bg;
                    VerticalBox {
                        padding: 22px;
                        spacing: 16px;

                        SectionPanel { title: "Recharge"; subtitle: "Mock payment packages aligned with the Flutter commercial desktop flow."; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; }

                        HorizontalBox {
                            spacing: 14px;
                            MetricTile { label: "Current plan"; value: account-tier; note: billing-plan-id; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-accent; }
                            MetricTile { label: "Quota"; value: "" + quota-remaining + " / " + quota-total; note: is-signed-in ? "Cloud conversions" : "Sign in required"; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-success; }
                            MetricTile { label: "Billing"; value: is-billing-busy ? "Working" : "Ready"; note: billing-status; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-warning; }
                        }

                        Rectangle {
                            border-radius: 8px;
                            border-color: color-border;
                            background: color-surface;
                            VerticalBox {
                                padding: 18px;
                                spacing: 12px;
                                Text { text: "Recharge by count"; font-size: 16px; font-weight: 700; color: color-text-primary; }
                                HorizontalBox {
                                    spacing: 10px;
                                    Button { text: "100 conversions"; primary: billing-plan-id == "count-100"; clicked => { billing-plan-id = "count-100"; change-plan-clicked("count-100"); toast-message = "Selected 100 conversion package."; toast-level = "info"; toast-visible = true; } }
                                    Button { text: "500 conversions"; primary: billing-plan-id == "count-500"; clicked => { billing-plan-id = "count-500"; change-plan-clicked("count-500"); toast-message = "Selected 500 conversion package."; toast-level = "info"; toast-visible = true; } }
                                    Button { text: "2000 conversions"; primary: billing-plan-id == "count-2000"; clicked => { billing-plan-id = "count-2000"; change-plan-clicked("count-2000"); toast-message = "Selected 2000 conversion package."; toast-level = "info"; toast-visible = true; } }
                                }
                                Text { text: "Recharge by date"; font-size: 16px; font-weight: 700; color: color-text-primary; }
                                HorizontalBox {
                                    spacing: 10px;
                                    Button { text: "30 days"; clicked => { billing-plan-id = "date-30"; change-plan-clicked("date-30"); } }
                                    Button { text: "180 days"; clicked => { billing-plan-id = "date-180"; change-plan-clicked("date-180"); } }
                                    Button { text: "365 days"; clicked => { billing-plan-id = "date-365"; change-plan-clicked("date-365"); } }
                                }
                                HorizontalBox {
                                    spacing: 10px;
                                    Button { text: t-billing-plans; enabled: api-base-url != ""; clicked => { is-billing-busy = true; show-plans-clicked(api-base-url); } }
                                    Button { text: "Mock Pay"; primary: true; enabled: api-base-url != "" && billing-plan-id != ""; clicked => { is-billing-busy = true; checkout-clicked(api-base-url, billing-plan-id); toast-message = "Mock payment submitted."; toast-level = "success"; toast-visible = true; } }
                                    Button { text: t-billing-portal; enabled: api-base-url != ""; clicked => { is-billing-busy = true; billing-portal-clicked(api-base-url); } }
                                }
                                Text { text: billing-status; font-size: 12px; color: color-text-secondary; wrap: word-wrap; }
                            }
                        }
                    }
                }

                if selected-page == 2: Rectangle {
                    background: color-window-bg;
                    VerticalBox {
                        padding: 22px;
                        spacing: 14px;

                        SectionPanel { title: t-convert-cloud-convert; subtitle: "Upload a complete LaTeX project, choose the main TeX file, and run the semantic conversion engine."; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; }

                        Rectangle {
                            border-radius: 8px;
                            border-color: color-border;
                            background: color-surface;
                            VerticalBox {
                                padding: 18px;
                                spacing: 10px;

                                HorizontalBox {
                                    spacing: 8px;
                                    LineEdit { placeholder-text: t-convert-project-placeholder; text <=> project-path; }
                                    Button { text: t-convert-folder; enabled: !is-converting; clicked => { choose-project-folder-clicked(project-path, output-path); } }
                                    Button { text: t-convert-zip; enabled: !is-converting; clicked => { choose-project-zip-clicked(project-path, output-path); } }
                                }

                                LineEdit { placeholder-text: t-convert-main-tex-placeholder; text <=> main-tex; }

                                HorizontalBox {
                                    spacing: 10px;
                                    ComboBox { current-value <=> detected-profile; model: ["auto", "generic-article", "tacl", "cvpr", "nature", "springer", "jos-paper", "chinese-academic"]; }
                                    ComboBox { current-value <=> quality-level; model: ["preview", "standard", "strict"]; }
                                    Switch { text: t-convert-cloud; checked <=> use-cloud-engine; enabled: is-signed-in; }
                                }

                                HorizontalBox {
                                    spacing: 8px;
                                    LineEdit { placeholder-text: t-convert-output-placeholder; text <=> output-path; }
                                    Button { text: t-convert-save-as; clicked => { choose-output-clicked(output-path); } }
                                }

                                HorizontalBox {
                                    spacing: 10px;
                                    Button { text: t-convert-detect-profile; enabled: project-path != "" && !is-converting; clicked => { status-text = t-convert-detecting-profile + project-path; detect-profile-clicked(project-path); } }
                                    Button {
                                        text: is-converting ? t-convert-converting : (use-cloud-engine ? t-convert-cloud-convert : t-convert-convert);
                                        primary: true;
                                        enabled: !is-converting && project-path != "" && output-path != "" && (!use-cloud-engine || is-signed-in);
                                        clicked => {
                                            is-converting = true;
                                            conversion-progress = 0.15;
                                            if use-cloud-engine {
                                                cloud-convert-clicked(api-base-url, project-path, main-tex, detected-profile, quality-level, output-path);
                                            } else {
                                                convert-clicked(project-path, detected-profile, quality-level, output-path);
                                            }
                                        }
                                    }
                                    Button { text: t-convert-open-output; enabled: output-path != ""; clicked => { open-output-clicked(output-path); } }
                                    Button { text: t-convert-open-report; enabled: output-path != ""; clicked => { open-report-clicked(output-path); } }
                                }

                                ProgressIndicator { progress: is-converting ? conversion-progress : 0.0; }
                                Text { text: status-text == "" ? t-convert-ready : status-text; font-size: 12px; color: color-text-secondary; wrap: word-wrap; }
                            }
                        }

                        HorizontalBox {
                            spacing: 14px;
                            MetricTile { label: t-common-compatibility; value: compatibility-score; note: "Profile " + detected-profile; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-accent; }
                            MetricTile { label: "Quality"; value: quality-status; note: quality-level; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-success; }
                            MetricTile { label: t-common-confidence; value: profile-confidence; note: t-convert-detected; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; accent: color-warning; }
                        }
                    }
                }

                if selected-page == 3: Rectangle {
                    background: color-window-bg;
                    VerticalBox {
                        padding: 22px;
                        spacing: 14px;
                        SectionPanel { title: "Conversion Records"; subtitle: "Recent local and cloud conversion jobs."; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; }
                        Rectangle {
                            border-radius: 8px;
                            border-color: color-border;
                            background: color-surface;
                            VerticalBox {
                                padding: 14px;
                                spacing: 8px;
                                if job-history.length == 0: Text { text: recent-jobs; font-size: 12px; color: color-text-secondary; wrap: word-wrap; }
                                ListView {
                                    visible: job-history.length > 0;
                                    height: 390px;
                                    for row[idx] in job-history: Rectangle {
                                        min-height: 46px;
                                        background: Math.mod(idx, 2) == 0 ? color-surface : color-surface-alt;
                                        HorizontalBox {
                                            padding: 8px;
                                            spacing: 10px;
                                            Text { text: row.status; width: 96px; font-size: 11px; color: row.status == "Succeeded" ? color-success : (row.status == "Failed" ? color-danger : color-accent); }
                                            Text { text: row.input; horizontal-stretch: 1; font-size: 11px; color: color-text-secondary; overflow: elide; }
                                            Text { text: row.opened-at; width: 138px; font-size: 10px; color: color-text-muted; overflow: elide; }
                                            Button { text: "Remove"; clicked => { remove-job-clicked(row.id); } }
                                        }
                                    }
                                }
                                HorizontalBox {
                                    spacing: 10px;
                                    Button { text: t-history-open-output; enabled: output-path != ""; clicked => { open-output-clicked(output-path); } }
                                    Button { text: t-history-open-report; enabled: output-path != ""; clicked => { open-report-clicked(output-path); } }
                                    Button { text: t-history-export-diagnostics; clicked => { export-diagnostics-clicked(project-path, output-path, api-base-url, detected-profile, quality-level, status-text, recent-jobs, update-status); } }
                                    Button { text: "Clear"; enabled: job-history.length > 0; clicked => { clear-jobs-clicked(); } }
                                }
                            }
                        }
                    }
                }

                if selected-page == 4: Rectangle {
                    background: color-window-bg;
                    VerticalBox {
                        padding: 22px;
                        spacing: 14px;
                        SectionPanel { title: "Recharge Records"; subtitle: "Mock recharge events and billing status are shown here until the commercial API exposes a dedicated record endpoint."; surface: color-surface; border: color-border; text-primary: color-text-primary; text-muted: color-text-muted; }
                        Rectangle {
                            border-radius: 8px;
                            border-color: color-border;
                            background: color-surface;
                            VerticalBox {
                                padding: 18px;
                                spacing: 12px;
                                HorizontalBox {
                                    spacing: 12px;
                                    StatusPill { text: billing-plan-id; bg: #eff6ff; fg: color-accent; }
                                    StatusPill { text: is-billing-busy ? "processing" : "idle"; bg: #ecfdf5; fg: color-success; }
                                    StatusPill { text: account-tier; bg: #fffbeb; fg: color-warning; }
                                }
                                Text { text: billing-status == "--" ? "No recharge record yet. Complete a mock payment from the Recharge page." : billing-status; font-size: 13px; color: color-text-secondary; wrap: word-wrap; }
                                Text { text: "Last package: " + billing-plan-id + "\nAccount: " + account-display-name + "\nQuota: " + quota-remaining + " / " + quota-total; font-size: 12px; color: color-text-muted; wrap: word-wrap; }
                                Button { text: "Go to Recharge"; clicked => { selected-page = 1; } }
                            }
                        }
                    }
                }
            }
        }
    }

    if account-menu-open: Rectangle {
        x: root.width - 230px;
        y: 58px;
        width: 208px;
        height: 144px;
        border-radius: 8px;
        border-color: color-border;
        background: color-surface;
        VerticalBox {
            padding: 10px;
            spacing: 6px;
            Button { text: "View Profile"; clicked => { profile-dialog-open = true; account-menu-open = false; } }
            Button { text: "Change Password"; enabled: is-signed-in; clicked => { password-dialog-open = true; account-menu-open = false; } }
            Button { text: t-account-logout; enabled: is-signed-in; clicked => { logout-clicked(); account-menu-open = false; } }
        }
    }

    if profile-dialog-open: Rectangle {
        x: (root.width - 420px) / 2;
        y: 132px;
        width: 420px;
        height: 260px;
        border-radius: 8px;
        border-color: color-border;
        background: color-surface;
        VerticalBox {
            padding: 22px;
            spacing: 12px;
            Text { text: "Account Details"; font-size: 20px; font-weight: 700; color: color-text-primary; }
            Text { text: "Email: " + login-email + "\nDisplay: " + account-display-name + "\nPlan: " + account-tier + "\nQuota: " + quota-remaining + " / " + quota-total; color: color-text-secondary; font-size: 13px; wrap: word-wrap; }
            Button { text: "Close"; clicked => { profile-dialog-open = false; } }
        }
    }

    if password-dialog-open: Rectangle {
        x: (root.width - 420px) / 2;
        y: 120px;
        width: 420px;
        height: 318px;
        border-radius: 8px;
        border-color: color-border;
        background: color-surface;
        VerticalBox {
            padding: 22px;
            spacing: 10px;
            Text { text: "Change Password"; font-size: 20px; font-weight: 700; color: color-text-primary; }
            LineEdit { placeholder-text: "Current password"; text <=> password-old; }
            LineEdit { placeholder-text: "New password"; text <=> password-new; }
            LineEdit { placeholder-text: "Confirm new password"; text <=> password-confirm; }
            Text { text: password-new != password-confirm ? "Passwords do not match." : ""; color: color-danger; font-size: 12px; }
            HorizontalBox {
                spacing: 10px;
                Button { text: "Cancel"; clicked => { password-dialog-open = false; } }
                Button {
                    text: "Confirm";
                    primary: true;
                    enabled: password-new == password-confirm && password-new != "";
                    clicked => {
                        password-dialog-open = false;
                        toast-message = "Password changed successfully.";
                        toast-level = "success";
                        toast-visible = true;
                    }
                }
            }
        }
    }

    if toast-visible: Rectangle {
        x: root.width - 360px;
        y: root.height - 88px;
        width: 330px;
        height: 54px;
        border-radius: 8px;
        background: toast-level == "success" ? #ecfdf5 : (toast-level == "error" ? #fef2f2 : #eff6ff);
        border-color: toast-level == "success" ? color-success : (toast-level == "error" ? color-danger : color-accent);
        HorizontalBox {
            padding: 12px;
            spacing: 10px;
            Text { text: toast-message; horizontal-stretch: 1; font-size: 12px; color: color-text-primary; overflow: elide; vertical-alignment: center; }
            Button { text: "OK"; clicked => { toast-visible = false; } }
        }
    }
}
